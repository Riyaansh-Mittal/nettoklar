---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://nettoklar.de/wert-der-rentenpunkte/#webpage",
      "url": "https://nettoklar.de/wert-der-rentenpunkte/",
      "name": "Wert der Rentenpunkte 2026 – Historische Tabelle & Rechner",
      "headline": "Wert der Rentenpunkte 2026 – Aktueller Rentenpunktwert, historische Tabelle & Rechner",
      "datePublished": "2026-04-26",
      "dateModified": "2026-05-05",
      "inLanguage": "de-DE",
      "isPartOf": { "@id": "https://nettoklar.de/#website" },
      "breadcrumb": { "@id": "https://nettoklar.de/wert-der-rentenpunkte/#breadcrumb" },
      "author": {
        "@type": "Person",
        "name": "Riyaansh Mittal",
        "url": "https://nettoklar.de/ueber-uns/"
      },
      "publisher": {
        "@type": "Organization",
        "name": "NettoKlar",
        "@id": "https://nettoklar.de/#organization",
        "url": "https://nettoklar.de/"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://nettoklar.de/wert-der-rentenpunkte/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "NettoKlar", "item": "https://nettoklar.de/" },
        { "@type": "ListItem", "position": 2, "name": "Wert der Rentenpunkte 2026", "item": "https://nettoklar.de/wert-der-rentenpunkte/" }
      ]
    },
    {
      "@type": "Dataset",
      "@id": "https://nettoklar.de/wert-der-rentenpunkte/#dataset",
      "name": "Rentenwert Deutschland 2018–2026",
      "description": "Historische Entwicklung des Rentenwerts West und Ost in Deutschland von 2018 bis 2026, inklusive jährlicher Anpassungsraten.",
      "temporalCoverage": "2018/2026",
      "spatialCoverage": "DE",
      "inLanguage": "de-DE",
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "publisher": {
        "@id": "https://nettoklar.de/#organization"
      },
      "creator": {
        "@id": "https://nettoklar.de/#organization"
      },
      "variableMeasured": [
        {
          "@type": "PropertyValue",
          "name": "Rentenwert West",
          "unitCode": "EUR",
          "description": "Aktueller Rentenwert West in Euro pro Monat pro Entgeltpunkt"
        },
        {
          "@type": "PropertyValue",
          "name": "Rentenwert Ost",
          "unitCode": "EUR",
          "description": "Aktueller Rentenwert Ost in Euro pro Monat pro Entgeltpunkt (seit Juli 2024 = West)"
        }
      ],
      "isBasedOn": {
        "@type": "CreativeWork",
        "name": "Sozialversicherungsrechengrößenverordnung 2026",
        "publisher": {
          "@type": "GovernmentOrganization",
          "name": "Bundesministerium für Arbeit und Soziales",
          "url": "https://www.bmas.de"
        }
      }
    },
    {
      "@type": "FAQPage",
      "@id": "https://nettoklar.de/wert-der-rentenpunkte/#faq",
      "dateModified": "2026-05-05",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Wie viel ist ein Rentenpunkt 2026 wert?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ein Rentenpunkt ist von Januar bis Juni 2026 genau 40,79 Euro pro Monat wert. Ab dem 1. Juli 2026 steigt der Wert durch die Rentenanpassung auf 42,52 Euro monatlich. West und Ost sind seit Juli 2024 gleichgestellt."
          }
        },
        {
          "@type": "Question",
          "name": "Wie viele Rentenpunkte brauche ich für 2.000 Euro Rente?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ab Juli 2026 (Rentenwert 42,52 Euro) benötigen Sie für eine Bruttorente von 2.000 Euro monatlich ca. 47 Rentenpunkte (2.000 ÷ 42,52). Für 1.500 Euro reichen ca. 35 Punkte, für 2.500 Euro ca. 59 Punkte."
          }
        },
        {
          "@type": "Question",
          "name": "Sind 40 Rentenpunkte gut?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "40 Punkte × 42,52 Euro (ab Juli 2026) ergeben eine Bruttorente von 1.700,80 Euro monatlich. Nach Abzug von Kranken- und Pflegeversicherung (ca. 14,2% gesamt) verbleiben netto rund 1.460 Euro. Bei durchschnittlichem Einkommen entspricht das etwa 40 Arbeitsjahren."
          }
        },
        {
          "@type": "Question",
          "name": "Wie sammelt man Rentenpunkte?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ein voller Entgeltpunkt entspricht einem Arbeitsjahr mit dem Durchschnittsverdienst (2026: ca. 51.944 Euro brutto jährlich). Wer weniger verdient, sammelt anteilig weniger Punkte. Kinderziehungsjahre, Pflegezeiten und freiwillige Beiträge können ebenfalls Punkte gutschreiben."
          }
        },
        {
          "@type": "Question",
          "name": "Wie viele Rentenpunkte sollte man mit 50 haben?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Als Faustregel: Bei 25 Arbeitsjahren mit Durchschnittsverdienst ca. 25 Punkte. Das projiziert auf ca. 38–40 Punkte bis zum Renteneintritt mit 67. Wer deutlich darunter liegt, kann über den freiwilligen Kauf von Rentenpunkten nachdenken."
          }
        }
      ]
    },
    {
      "@type": "WebApplication",
      "@id": "https://nettoklar.de/wert-der-rentenpunkte/#app",
      "name": "Rentenpunkte-Rechner 2026 (Vorwärts & Rückwärts)",
      "url": "https://nettoklar.de/wert-der-rentenpunkte/",
      "description": "Berechnen Sie Ihre monatliche Bruttorente aus Ihrer Punkteanzahl – oder ermitteln Sie, wie viele Rentenpunkte Sie für Ihre Wunschrente benötigen.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web",
      "browserRequirements": "Requires JavaScript",
      "inLanguage": "de-DE",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" }
    },
    {
      "@type": "SpeakableSpecification",
      "@id": "https://nettoklar.de/wert-der-rentenpunkte/#speakable",
      "cssSelector": [".direct-answer", ".fact-strip", "h1"]
    }
  ]
};
---

<BaseLayout
  title="Rentenpunkt 2026: €40,79 / ab Juli €42,52 + Rechner"
  description="1 Rentenpunkt = €40,79 (Jan–Jun 2026), ab Juli €42,52. Historische Rentenwert-Tabelle 2018–2026. Rechner: Wunschrente & benötigte Punkte. DRV-Quelle."
  schema={schema}
  canonical="https://nettoklar.de/wert-der-rentenpunkte/"
>
  <a href="#main-content" class="sr-only">Zum Inhalt springen</a>

  <main id="main-content">
    <div class="page-wrapper">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
          <li><a href="/">NettoKlar</a></li>
          <li>Wert der Rentenpunkte 2026</li>
        </ol>
      </nav>

      <article>

        <!-- Article Header -->
        <header class="article-header">
          <h1>Wert der Rentenpunkte 2026 – Aktueller Rentenpunktwert, historische Tabelle &amp; Rechner</h1>
          <div class="author-byline">
            <span>Von <strong>Riyaansh Mittal</strong></span>
            <span class="byline-sep">·</span>
            <span>Aktualisiert: Mai 2026</span>
            <span class="byline-sep">·</span>
            <span>Lesezeit: ca. 6 Minuten</span>
            <span class="byline-sep">·</span>
            <span class="freshness-badge">✓ Geprüft 2026</span>
          </div>
        </header>

        <!-- Direct Answer (above the fold — cited by LLMs) -->
        <p class="direct-answer">
          Ein Rentenpunkt ist <strong>von Januar bis Juni 2026 genau €40,79/Monat</strong> wert.
          Ab dem <strong>1. Juli 2026 steigt der Rentenwert auf €42,52/Monat</strong> (+4,24%).
          West und Ost sind seit Juli 2024 vollständig angeglichen.
          Für eine Bruttorente von €2.000/Monat benötigen Sie ab Juli 2026 ca. <strong>47 Rentenpunkte</strong>.
        </p>

        <div class="faq-preview-strip">
          <span class="faq-preview-label">Häufige Fragen:</span>
          <a href="#faq-wert">Wert 2026?</a>
          <a href="#faq-2000">Punkte für €2.000?</a>
          <a href="#faq-40punkte">Sind 40 Punkte gut?</a>
          <a href="#faq-sammeln">Wie sammelt man Punkte?</a>
          <a href="#faq-mit50">Punkte mit 50?</a>
          <a href="#faq-letzte-jahre">Letzte 5 Jahre wichtig?</a>
          <a href="#faq" class="faq-preview-all">Alle FAQs →</a>
        </div>

        <!-- Jump Nav -->
        <nav class="article-jump-nav" aria-label="Seitennavigation">
          <span class="jump-nav-label">Auf dieser Seite:</span>
          <a href="#aktuell">Aktueller Wert</a>
          <a href="#historisch">Historische Tabelle</a>
          <a href="#rechner-vorwaerts">Rechner A</a>
          <a href="#rechner-rueckwaerts">Rechner B</a>
          <a href="#sammeln">Punkte sammeln</a>
          <a href="#kaufen">Punkte kaufen</a>
          <a href="#faq">FAQ</a>
        </nav>

        <!-- Fact Strip -->
        <dl class="fact-strip">
          <div class="fact-item">
            <dt>Rentenpunktwert Jan–Jun 2026</dt>
            <dd>€40,79</dd>
          </div>
          <div class="fact-item">
            <dt>Rentenpunktwert ab Jul 2026</dt>
            <dd>€42,52</dd>
          </div>
          <div class="fact-item">
            <dt>Rentenanpassung Juli 2026</dt>
            <dd>+4,24%</dd>
          </div>
          <div class="fact-item">
            <dt>Durchschnittsverdienst 2026 (DRV)</dt>
            <dd>€51.944</dd>
          </div>
          <div class="fact-item">
            <dt>West = Ost seit</dt>
            <dd>Juli 2024</dd>
          </div>
          <div class="fact-item">
            <dt>Punkte für €2.000/Monat</dt>
            <dd>~47 Punkte</dd>
          </div>
        </dl>

        <div class="article-body">

          <!-- ══ H2 1: Aktueller Wert ══ -->
          <section id="aktuell" class="anchor-section">
            <h2>Aktueller Rentenpunktwert 2026 – Übersicht</h2>

            <div class="summary-card">
              <h2>Rentenpunktwert auf einen Blick</h2>
              <div class="table-scroll table-scroll--wide">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Zeitraum</th>
                      <th>Rentenpunktwert West</th>
                      <th>Rentenpunktwert Ost</th>
                      <th>Änderung</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr class="highlight-row">
                      <td><strong>Ab Juli 2026</strong></td>
                      <td><strong>€42,52</strong></td>
                      <td><strong>€42,52</strong></td>
                      <td><strong>+4,24%</strong></td>
                    </tr>
                    <tr>
                      <td>Jan 2026 – Jun 2026</td>
                      <td>€40,79</td>
                      <td>€40,79</td>
                      <td>—</td>
                    </tr>
                    <tr>
                      <td>2025 (Vergleich)</td>
                      <td>€39,32</td>
                      <td>€39,32</td>
                      <td>+4,6%</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <p>
              Seit Juli 2024 gilt für West und Ost derselbe Rentenpunktwert — die jahrzehntelange
              Ungleichbehandlung ist vollständig abgebaut. Ab dem <strong>1. Juli 2026</strong> steigt
              der Wert von €40,79 auf <strong>€42,52 pro Monat und Rentenpunkt</strong>.
            </p>
          </section>

          <!-- ══ H2 2: Historische Tabelle (Dataset — 4–6× citation lift) ══ -->
          <section id="historisch" class="anchor-section">
            <h2>Historische Rentenwert-Tabelle 2018–2026</h2>
            <p>
              Die folgende Tabelle zeigt die Entwicklung des aktuellen Rentenwerts seit 2018.
              Quelle: <a href="https://www.deutsche-rentenversicherung.de" target="_blank" rel="noopener noreferrer">Deutsche Rentenversicherung (DRV)</a>,
              Sozialversicherungsrechengrößenverordnung, jeweils gültige Fassung.
            </p>

            <div class="table-scroll">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Jahr</th>
                    <th>Rentenwert West</th>
                    <th>Rentenwert Ost</th>
                    <th>Änderung (West)</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="highlight-row">
                    <td><strong>2026 (ab Juli)</strong></td>
                    <td><strong>€42,52</strong></td>
                    <td><strong>€42,52</strong></td>
                    <td><strong>+4,24%</strong></td>
                  </tr>
                  <tr>
                    <td>2025</td>
                    <td>€39,32 → €40,79</td>
                    <td>€39,32 → €40,79</td>
                    <td>+4,6%</td>
                  </tr>
                  <tr>
                    <td>2024</td>
                    <td>€37,60 → €39,32</td>
                    <td>€37,60 → €39,32</td>
                    <td>+5,9% (Ost angeglichen)</td>
                  </tr>
                  <tr>
                    <td>2023</td>
                    <td>€36,02 → €37,60</td>
                    <td>€35,52 → €36,02</td>
                    <td>+4,4% West / +5,86% Ost</td>
                  </tr>
                  <tr>
                    <td>2022</td>
                    <td>€34,19 → €36,02</td>
                    <td>€33,47 → €35,52</td>
                    <td>+5,35% West</td>
                  </tr>
                  <tr>
                    <td>2021</td>
                    <td>€34,19</td>
                    <td>€33,47</td>
                    <td>0% (Schutzklausel)</td>
                  </tr>
                  <tr>
                    <td>2020</td>
                    <td>€34,19</td>
                    <td>€33,23</td>
                    <td>+3,45%</td>
                  </tr>
                  <tr>
                    <td>2019</td>
                    <td>€33,05</td>
                    <td>€31,89</td>
                    <td>+3,18%</td>
                  </tr>
                  <tr>
                    <td>2018</td>
                    <td>€32,03</td>
                    <td>€30,69</td>
                    <td>+3,22%</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p style="font-size: var(--text-xs); color: var(--color-text-muted)">
              Werte jeweils ab 1. Juli des angegebenen Jahres. Ost-Wert ab Juli 2024 = West-Wert (vollständige Angleichung).
              Quelle: DRV, BMAS, Bundesgesetzblatt.
            </p>
          </section>

          <!-- ══ H2 3: Rechner A ══ -->
          <section id="rechner-vorwaerts" class="anchor-section">
            <h2>Wie viel Rente bekomme ich? – Rentenpunkte Rechner</h2>
            <p>Geben Sie Ihre gesammelten Entgeltpunkte ein und wählen Sie Ihren Renteneintritt:</p>

            <div class="calculator-card">
              <h2>Rechner A — Punkte → Monatsrente</h2>
              <p class="calc-subtitle">Berechnen Sie Ihre monatliche Bruttorente aus Ihren Entgeltpunkten.</p>

              <div class="calc-field-group">
                <label class="calc-label" for="punkte-input">Meine Rentenpunkte (Entgeltpunkte)</label>
                <div class="input-euro-wrap">
                  <input class="calc-input" type="number" id="punkte-input"
                         min="0" max="100" step="0.1" placeholder="z.B. 35" />
                  <span class="input-euro-symbol">EP</span>
                </div>
                <div class="preset-row">
                  <button class="preset-chip" data-target="punkte-input" data-val="20">20</button>
                  <button class="preset-chip" data-target="punkte-input" data-val="35">35</button>
                  <button class="preset-chip" data-target="punkte-input" data-val="45">45</button>
                  <button class="preset-chip" data-target="punkte-input" data-val="60">60</button>
                </div>
              </div>

              <div class="calc-field-group">
                <label class="calc-label">Zeitraum</label>
                <div class="toggle-group">
                  <button class="toggle-btn active" data-rentenwert="40.79">Bis Jun 2026 (€40,79)</button>
                  <button class="toggle-btn" data-rentenwert="42.52">Ab Jul 2026 (€42,52)</button>
                </div>
              </div>

              <div class="calc-field-group">
                <label class="calc-label">Renteneintritt</label>
                <div class="toggle-group">
                  <button class="toggle-btn active" data-eintritt="normal">Regelaltersgrenze</button>
                  <button class="toggle-btn" data-eintritt="frueh">Früher</button>
                  <button class="toggle-btn" data-eintritt="spaet">Später</button>
                </div>
              </div>

              <div class="calc-field-group hidden" id="monate-group">
                <label class="calc-label" for="monate-input" id="monate-label">
                  Monate vor Regelaltersgrenze (max. 48)
                </label>
                <div class="input-euro-wrap">
                  <input class="calc-input" type="number" id="monate-input"
                         min="1" max="48" step="1" placeholder="z.B. 24" />
                  <span class="input-euro-symbol">Mo</span>
                </div>
                <p class="calc-hint" id="zugangsfaktor-hint"></p>
              </div>

              <div class="result-block" id="result-vorwaerts" aria-live="polite">
                <p class="result-label">Monatliche Bruttorente</p>
                <div class="result-badge" id="rente-output" style="min-width: 120px; text-align: center;">–</div>
              </div>
            </div>

            <!-- Quick reference table -->
            <h3 style="margin-top: var(--space-8); margin-bottom: var(--space-4); font-size: var(--text-lg)">Schnellübersicht: Wie viel Rente für wie viele Punkte?</h3>
            <div class="table-scroll">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Rentenpunkte</th>
                    <th>Bruttorente/Monat (ab Jul 2026, €42,52)</th>
                    <th>Entspricht ca.</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>20 Punkte</td>
                    <td>€850,40</td>
                    <td>~20 Arbeitsjahre Ø-Verdienst</td>
                  </tr>
                  <tr>
                    <td>35 Punkte</td>
                    <td>€1.488,20</td>
                    <td>~35 Arbeitsjahre Ø-Verdienst</td>
                  </tr>
                  <tr class="highlight-row">
                    <td><strong>45 Punkte</strong></td>
                    <td><strong>€1.913,40</strong></td>
                    <td><strong>~45 Arbeitsjahre (typisch)</strong></td>
                  </tr>
                  <tr>
                    <td>60 Punkte</td>
                    <td>€2.551,20</td>
                    <td>Überdurchschnittliches Einkommen</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="inline-link-callout">
              <span>→</span>
              <span>Rentenpunkte nachkaufen? <a href="/rentenpunkte-kaufen/">Kosten, Tabelle &amp; ob es sich lohnt →</a></span>
            </div>
          </section>

          <!-- ══ H2 4: Rechner B ══ -->
          <section id="rechner-rueckwaerts" class="anchor-section">
            <h2>Wie viele Rentenpunkte brauche ich? – Rente rückwärts berechnen</h2>
            <p>Sie wissen, wie viel Rente Sie möchten — der Rechner zeigt, wie viele Punkte Sie dafür brauchen:</p>

            <div class="calculator-card">
              <h2>Rechner B — Wunschrente → Benötigte Punkte</h2>
              <p class="calc-subtitle">Geben Sie Ihre Wunsch-Monatsrente ein.</p>

              <div class="calc-field-group">
                <label class="calc-label" for="wunschrente-input">
                  Gewünschte Monatsrente (brutto)
                </label>
                <div class="input-euro-wrap">
                  <input class="calc-input" type="number" id="wunschrente-input"
                         min="0" max="10000" step="50" placeholder="z.B. 2000" />
                  <span class="input-euro-symbol">€</span>
                </div>
                <div class="preset-row">
                  <button class="preset-chip" data-target="wunschrente-input" data-val="1000">€1.000</button>
                  <button class="preset-chip" data-target="wunschrente-input" data-val="1500">€1.500</button>
                  <button class="preset-chip" data-target="wunschrente-input" data-val="2000">€2.000</button>
                  <button class="preset-chip" data-target="wunschrente-input" data-val="2500">€2.500</button>
                </div>
              </div>

              <div class="calc-field-group">
                <label class="calc-label">Zeitraum</label>
                <div class="toggle-group">
                  <button class="toggle-btn active" data-wert-b="40.79">Bis Jun 2026 (€40,79)</button>
                  <button class="toggle-btn" data-wert-b="42.52">Ab Jul 2026 (€42,52)</button>
                </div>
              </div>

              <div class="result-block hidden" id="result-rueckwaerts" aria-live="polite">
                <p class="result-label">Benötigte Rentenpunkte</p>
                <div class="result-badge" id="punkte-output" style="min-width: 120px; text-align: center;">–</div>
              </div>
            </div>

            <h3 style="margin-top: var(--space-8); margin-bottom: var(--space-4); font-size: var(--text-lg)">Schnellübersicht: Wie viele Punkte für welche Rente?</h3>
            <div class="table-scroll">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Gewünschte Monatsrente (brutto)</th>
                    <th>Benötigte Rentenpunkte (ab Jul 2026, €42,52)</th>
                  </tr>
                </thead>
                <tbody>
                  <tr><td>€1.000 / Monat</td><td>~24 Punkte</td></tr>
                  <tr><td>€1.500 / Monat</td><td>~35 Punkte</td></tr>
                  <tr class="highlight-row"><td><strong>€2.000 / Monat</strong></td><td><strong>~47 Punkte</strong></td></tr>
                  <tr><td>€2.500 / Monat</td><td>~59 Punkte</td></tr>
                  <tr><td>€3.000 / Monat</td><td>~71 Punkte</td></tr>
                </tbody>
              </table>
            </div>
          </section>

          <!-- ══ H2 5: Punkte sammeln ══ -->
          <section id="sammeln" class="anchor-section">
            <h2>Wie sammelt man Rentenpunkte? – Entgeltpunkte verstehen</h2>
            <p>
              Ein voller Entgeltpunkt entspricht einem Arbeitsjahr mit dem
              <strong>Durchschnittsverdienst 2026: €51.944 brutto/Jahr</strong> (offizieller DRV-Wert,
              Sozialversicherungsrechengrößenverordnung 2026). Wer mehr oder weniger verdient,
              sammelt proportional mehr oder weniger Punkte.
            </p>

            <div class="correction-callout">
              <span>⚠️</span>
              <div>
                <span class="correction-badge">Achtung</span>
                <p style="margin-top: var(--space-2); font-size: var(--text-sm); color: var(--color-text)">
                  Viele Quellen nennen noch €45.358 als Durchschnittsverdienst 2026. Das war der Wert für 2025.
                  Der offizielle DRV-Wert für 2026 ist <strong>€51.944/Jahr</strong> (Bundeskabinett, 8. Oktober 2025).
                </p>
