    </dl>

    <div class="summary-card">
      <h2>Das Wichtigste auf einen Blick</h2>
      <table class="data-table">
        <thead>
          <tr>
            <th>Frage</th>
            <th>Antwort</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Automatische Steuerklasse nach Heirat</td>
            <td><strong>IV / IV</strong></td>
          </tr>
          <tr>
            <td>Wann lohnt sich III / V?</td>
            <td>Ein Partner verdient ≥ 60% des gemeinsamen Einkommens</td>
          </tr>
          <tr>
