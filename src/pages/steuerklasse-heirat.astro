<BaseLayout
  title="Steuerklasse wechseln nach Heirat 2026 – ELSTER & Formular"
  description="Steuerklasse nach Heirat wechseln: Automatisch SK IV/IV. Wann lohnt SK 3/5? Schritt-für-Schritt via ELSTER (10 Min). Kein fester Stichtag seit 2020."
  schema={schema}
>
  <a href="#main-content" class="sr-only">Zum Inhalt springen</a>

  <main id="main-content">
    <div class="page-wrapper">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
          <li><a href="/">NettoKlar</a></li>
          <li>Steuerklasse nach Heirat</li>
        </ol>
      </nav>

      <article>

        <!-- Article Header -->
        <header class="article-header">
          <h1>Steuerklasse wechseln nach der Heirat – Antrag, ELSTER &amp; Formular</h1>
          <div class="author-byline">
            <span>Von <strong>Riyaansh Mittal</strong>, Finanz- und Steuerredakteur</span>
            <span class="byline-sep">·</span>
            <span>Aktualisiert: Mai 2026</span>
            <span class="byline-sep">·</span>
            <span>Lesezeit: ca. 6 Minuten</span>
