  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": "https://nettoklar.de/steuerklasse-heirat/#breadcrumb",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "NettoKlar", "item": "https://nettoklar.de/" },
