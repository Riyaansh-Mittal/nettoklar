        </dl>

        <!-- Summary Card -->
        <div class="summary-card">
          <h2>Das Wichtigste auf einen Blick</h2>
          <div class="table-scroll">
            <table class="data-table">
              <thead>
                <tr><th>Frage</th><th>Antwort</th></tr>
              </thead>
              <tbody>
                <tr>
                  <td>Automatische SK nach Heirat</td>
                  <td><strong>IV / IV</strong></td>
                </tr>
                <tr>
