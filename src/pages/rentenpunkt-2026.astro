const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": "https://nettoklar.de/rentenpunkt-2026/#webpage",
      "url": "https://nettoklar.de/rentenpunkt-2026/",
      "name": "Rentenpunkt 2026 – Wert, Kosten & Was sich ändert",
      "headline": "Rentenpunkt 2026 – Aktueller Wert, Kosten & Änderungen",
      "datePublished": "2026-04-24",
      "dateModified": "2026-04-24",
      "inLanguage": "de-DE",
      "isPartOf": { "@id": "https://nettoklar.de/#website" },
      "breadcrumb": { "@id": "https://nettoklar.de/rentenpunkt-2026/#breadcrumb" },
      "author": { "@type": "Organization", "name": "NettoKlar", "url": "https://nettoklar.de/" },
      "publisher": { "@type": "Organization", "name": "NettoKlar", "url": "https://nettoklar.de/" }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://nettoklar.de/rentenpunkt-2026/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "NettoKlar", "item": "https://nettoklar.de/" },
        { "@type": "ListItem", "position": 2, "name": "Rentenpunkt 2026", "item": "https://nettoklar.de/rentenpunkt-2026/" }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://nettoklar.de/rentenpunkt-2026/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Wie viel ist ein Rentenpunkt 2026 wert?",
          "acceptedAnswer": { "@type": "Answer", "text": "Von Januar bis Juni 2026 ist ein Rentenpunkt 40,79 Euro pro Monat wert. Ab dem 1. Juli 2026 steigt der Wert auf 42,52 Euro (Juli-Anpassung: +4,24%; gegenüber 2025 gesamt: +8,1%). West- und Ostdeutschland sind seit Juli 2024 gleichgestellt." }
        },
        {
          "@type": "Question",
          "name": "Was kostet ein Rentenpunkt 2026 beim Kauf?",
          "acceptedAnswer": { "@type": "Answer", "text": "Der Kauf eines Rentenpunktes kostet 2026 ca. 9.661,58 Euro. Nach dem Steuerabzug als Sonderausgaben (ca. 30% Steuersatz) reduzieren sich die Nettokosten auf ca. 6.763 Euro." }
        },
        {
          "@type": "Question",
          "name": "Wie viele Rentenpunkte bekommt man 2026 für ein Durchschnittsgehalt?",
          "acceptedAnswer": { "@type": "Answer", "text": "Wer 2026 genau das Durchschnittsentgelt (ca. 45.358 Euro brutto jährlich) verdient, sammelt exakt 1,0 Entgeltpunkt. Bei 30.000 Euro sind es ca. 0,66 Punkte; bei 60.000 Euro ca. 1,32 Punkte." }
        },
        {
          "@type": "Question",
          "name": "Was bedeutet Zwangsverrentung ab 2027?",
          "acceptedAnswer": { "@type": "Answer", "text": "Ab 2027 kann das Jobcenter Bürgergeld-Empfänger ab 63 Jahren zur vorzeitigen Inanspruchnahme der Altersrente verpflichten – auch mit dauerhaften Rentenabschlägen. Dies betrifft Langzeitarbeitslose, die sonst bis 67 warten würden." }
        }
      ]
    }
  ]
};
---

<BaseLayout
  title="Rentenpunkt 2026: Wert €42,52 & Kosten €9.661 – Übersicht"
  description="Rentenpunkt 2026: Wert ab Juli €42,52/Monat, Kauf kostet ~€9.661. Was sich ändert, wer kaufen darf & wie viel Rente 1 Punkt bringt – schnell erklärt."
  schema={schema}
>
  <main class="page-wrapper">
    <nav aria-label="Breadcrumb">
      <ol class="breadcrumb">
        <li><a href="/">NettoKlar</a></li>
        <li>Rentenpunkt 2026</li>
      </ol>
    </nav>

    <header class="article-header">
      <h1>Rentenpunkt 2026 – Aktueller Wert, Kosten & Änderungen</h1>
      <p class="article-meta">
        <span>Letzte Aktualisierung: 24. April 2026</span>
        <span>·</span>
        <span>Lesezeit: ca. 4 Minuten</span>
      </p>
    </header>

    <div class="summary-card">
      <h2>Rentenpunkt 2026 — Wert & Kosten auf einen Blick</h2>
      <table class="data-table">
        <thead>
          <tr>
            <th>Kennzahl</th>
            <th>Wert 2026</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Rentenpunktwert Jan–Jun 2026</td>
            <td><strong>€40,79 / Monat</strong></td>
          </tr>
          <tr class="highlight-row">
            <td>Rentenpunktwert ab 1. Juli 2026</td>
            <td><strong>€42,52 / Monat</strong></td>
          </tr>
          <tr>
            <td>Anstieg gegenüber 2025 (€39,32)</td>
            <td>+€3,20 <span style="color: var(--color-net);">(+8,1%)</span></td>
          </tr>
          <tr>
            <td>Kosten für 1 Rentenpunkt (Kauf)</td>
            <td><strong>~€9.661,58</strong></td>
          </tr>
          <tr>
            <td>Break-even bei Kauf</td>
            <td>~18–19 Jahre</td>
          </tr>
          <tr>
            <td>Steuerlich absetzbar?</td>
            <td>Ja — als Sonderausgaben</td>
          </tr>
        </tbody>
      </table>

      <table class="data-table" style="margin-top: var(--space-4);">
        <thead>
          <tr>
            <th>Jahr</th>
            <th>Rentenpunktwert (West = Ost)</th>
            <th>Jahresveränderung</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>2022</td><td>€36,02</td><td>+5,35%</td></tr>
          <tr><td>2023</td><td>€37,60</td><td>+4,39%</td></tr>
          <tr><td>2024</td><td>€39,32</td><td>+4,57%</td></tr>
          <tr><td>2025</td><td>€40,79</td><td>+3,74%</td></tr>
          <tr class="highlight-row">
            <td><strong>2026 (ab Jul)</strong></td>
            <td><strong>€42,52</strong></td>
            <td>+4,24%</td>
          </tr>
        </tbody>
      </table>
    </div>

    <article class="article-body">

      <h2>Was ist ein Rentenpunkt — Kurz erklärt</h2>
      <p>
        Ein Entgeltpunkt (= Rentenpunkt) entspricht einem Jahr, in dem Sie genau den
        deutschen Durchschnittsverdienst verdient haben. 2026 liegt dieser bei
        <strong>ca. €45.358 brutto pro Jahr</strong>.
      </p>
      <p>
        Verdienen Sie weniger, sammeln Sie anteilig weniger Punkte. Verdienen Sie mehr,
        sammeln Sie mehr — aber nur bis zur Beitragsbemessungsgrenze. Die gesammelten
        Punkte werden bei Renteneintritt mit dem aktuellen Rentenwert multipliziert:
      </p>

      <div class="summary-card" style="background: var(--color-primary-highlight); border-color: rgba(0,107,112,0.2);">
        <p style="font-family: var(--font-body); font-size: var(--text-base); font-weight: 500; color: var(--color-text); margin: 0;">
          Monatsrente = Rentenpunkte × <strong>€42,52</strong> (ab Juli 2026)
        </p>
        <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin-top: var(--space-2); margin-bottom: 0;">
          Beispiel: 40 Punkte × €42,52 = <strong>€1.700,80 / Monat brutto</strong>
        </p>
      </div>

      <h2>Was ändert sich ab Juli 2026?</h2>
      <p>
        Die Rentenanpassung 2026 erfolgt in zwei Stufen. Der Rentenwert stieg bereits
        zum Januar 2026 auf €40,79 (Ergebnis der 2025er Anpassungsrunde). Die
        <strong>offizielle Rentenanpassung zum 1. Juli 2026</strong> bringt den zweiten
        Schritt: +4,24% auf <strong>€42,52</strong>.
      </p>
      <p>
        Year-on-year gegenüber dem 2025er Ausgangswert (€39,32) ergibt sich ein
        Gesamtanstieg von <strong>+8,1%</strong> — die höchste kumulative Steigerung
        seit Jahren. Seit Juli 2024 gilt der gleiche Rentenwert für West- und
        Ostdeutschland — die langjährige Ost-West-Lücke wurde vollständig geschlossen.
      </p>
      <p>
        <strong>Auswirkung konkret:</strong> Wer 35 Rentenpunkte hat, bekommt ab Juli
        2026 statt €1.427,65 nun <strong>€1.488,20 pro Monat</strong> — ein Plus von
        €60,55 monatlich.
      </p>

      <div class="inline-link-callout">
        → Zwangsverrentung ab 2027: Jobcenter können Bürgergeld-Empfänger ab 63 Jahren
        in Frühverrentung schicken — auch mit Abschlägen.
        <a href="#faq">Details im FAQ</a>
      </div>

      <h2>Rentenpunkt kaufen oder selbst ansparen?</h2>
      <table class="data-table">
        <thead>
          <tr>
            <th>Weg</th>
            <th>Kosten pro Punkt</th>
            <th>Flexibilität</th>
            <th>Steuerbonus</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Regulär (Arbeit)</td>
            <td>Lohnabzug — kein Extraaufwand</td>
            <td>Automatisch</td>
            <td>Ja (AN-Anteil)</td>
          </tr>
          <tr class="highlight-row">
            <td><strong>Freiwillig kaufen</strong></td>
            <td><strong>~€9.661</strong></td>
            <td>Selbst steuerbar</td>
            <td>Ja (Sonderausgaben)</td>
          </tr>
          <tr>
            <td>Versorgungsausgleich</td>
            <td>Individuell</td>
            <td>Nur bei Scheidung</td>
            <td>Nein</td>
          </tr>
        </tbody>
      </table>
      <p>
        Ob sich der Kauf lohnt, hängt von Ihrem Alter, Steuersatz und der
        Lebenserwartung ab — der Break-even liegt bei ca. 18–19 Jahren Rentenbezug.
        <a href="/rentenpunkte-kaufen/">Lohnt sich der Kauf? → Zum Rechner</a>
      </p>

      <div class="summary-card" style="text-align: center;">
        <p style="font-weight: 600; font-size: var(--text-base); margin-bottom: var(--space-3); color: var(--color-text);">
          📊 Wie viel Rente bekomme ich insgesamt?
        </p>
        <p style="color: var(--color-text-muted); font-size: var(--text-sm); margin-bottom: var(--space-4);">
          Geben Sie Ihre gesammelten Rentenpunkte ein und berechnen Sie Ihre monatliche Rente.
        </p>
        <a href="/wert-der-rentenpunkte/" class="btn-primary">
          Zum Rentenpunkte-Rechner →
        </a>
      </div>

      <h2 id="faq">FAQ — Häufige Fragen zum Rentenpunkt 2026</h2>
      <div class="faq-list">

        <details class="faq-item">
          <summary>Wie viel ist ein Rentenpunkt 2026 wert?</summary>
          <div class="faq-answer">
            <p>Von Januar bis Juni 2026: <strong>€40,79 / Monat</strong>. Ab 1. Juli 2026: <strong>€42,52 / Monat</strong> (+4,24% Rentenanpassung). Gegenüber dem 2025er Wert (€39,32) ein Gesamtanstieg von +8,1%. West- und Ostdeutschland gleichgestellt seit Juli 2024.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary>Was kostet ein Rentenpunkt 2026 beim Kauf?</summary>
          <div class="faq-answer">
            <p>Ca. <strong>€9.661,58</strong> brutto. Nach Steuerabzug als Sonderausgaben (ca. 30% Steuersatz) reduzieren sich die Nettokosten auf ca. <strong>€6.763</strong>. Der Break-even liegt bei ca. 18–19 Jahren Rentenbezug.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary>Wie viele Rentenpunkte bekommt man 2026 für ein Durchschnittsgehalt?</summary>
          <div class="faq-answer">
            <p>Beim Durchschnittsentgelt (~€45.358/Jahr) exakt <strong>1,0 Punkte</strong>. Bei €30.000/Jahr ca. 0,66 Punkte. Bei €60.000/Jahr ca. 1,32 Punkte (gedeckelt durch Beitragsbemessungsgrenze). Teilzeitkräfte und Geringverdiener sammeln entsprechend anteilig weniger.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary>Was bedeutet Zwangsverrentung ab 2027?</summary>
          <div class="faq-answer">
            <p>Ab 2027 kann das Jobcenter Bürgergeld-Empfänger ab 63 Jahren zur vorzeitigen Altersrente verpflichten — auch wenn das dauerhafte Abschläge von bis zu 14,4% bedeutet. Betroffen sind Langzeitarbeitslose, die ohne diese Regelung bis zum 67. Lebensjahr gewartet hätten.</p>
          </div>
        </details>

      </div>

      <div class="cta-group">
        <a href="/wert-der-rentenpunkte/" class="btn-primary">
          Meine Rente berechnen → Rentenpunkte-Rechner
        </a>
        <a href="/rentenpunkte-kaufen/" class="btn-secondary">
          Lohnt sich Rentenpunkte kaufen? →
        </a>
      </div>

    </article>
  </main>
</BaseLayout>