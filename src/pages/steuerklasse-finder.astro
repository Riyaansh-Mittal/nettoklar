<script>
(function () {
  var radios      = document.querySelectorAll<HTMLInputElement>('input[name="familienstand"]');
  var stepAE      = document.getElementById('step-alleinerziehend')!;
  var stepEK      = document.getElementById('step-einkommen')!;
  var slider      = document.getElementById('einkommensanteil') as HTMLInputElement;
  var anteilDisp  = document.getElementById('anteil-display')!;
  var partnerDisp = document.getElementById('partner-anteil')!;
  var btn         = document.getElementById('sk-finder-btn')!;
  var resultBox   = document.getElementById('sk-result')!;
  var badge       = document.getElementById('sk-badge')!;
  var reason      = document.getElementById('sk-reason')!;
  var ctaLink     = document.getElementById('sk-cta') as HTMLAnchorElement;
  var shareRow    = document.getElementById('sk-share-row')!;
  var embedBtn    = document.getElementById('embed-btn')!;
  var embedModal  = document.getElementById('embed-modal')!;
  var closeEmbed  = document.getElementById('close-embed')!;
  var copyEmbed   = document.getElementById('copy-embed')!;

  /* ── Show/hide conditional steps ── */
  function showHideSteps(): void {
    var checked = document.querySelector<HTMLInputElement>('input[name="familienstand"]:checked');
    stepAE.classList.add('hidden');
    stepEK.classList.add('hidden');
    resultBox.classList.add('hidden');
    if (!checked) return;
    if (checked.value === 'ledig')       stepAE.classList.remove('hidden');
    if (checked.value === 'verheiratet') stepEK.classList.remove('hidden');
  }
  radios.forEach(function (r) { r.addEventListener('change', showHideSteps); });

  /* ── Slider ── */
  slider.addEventListener('input', function () {
    anteilDisp.textContent  = slider.value + '%';
    partnerDisp.textContent = (100 - parseInt(slider.value)) + '%';
    resultBox.classList.add('hidden');
  });

  /* ── Preset chips ── */
  document.querySelectorAll<HTMLButtonElement>('.preset-chip[data-anteil]').forEach(function (chip) {
    chip.addEventListener('click', function () {
      slider.value            = chip.dataset.anteil!;
      anteilDisp.textContent  = chip.dataset.anteil + '%';
      partnerDisp.textContent = (100 - parseInt(chip.dataset.anteil!)) + '%';
      resultBox.classList.add('hidden');
    });
  });

  /* ── Core logic ── */
  interface SKResult {
    sk: string;
    text: string;
    link: string | null;
    linkText: string | null;
  }

  function getSK(fs: string, ae: string, anteil: number, zweit: string): SKResult {
    if (zweit === 'ja') return {
      sk: 'Steuerklasse 6',
      text: 'Jeder zweite sozialversicherungspflichtige Job wird automatisch mit SK 6 besteuert — unabhängig vom Familienstand. Es gibt keinen Grundfreibetrag, daher sind die Abzüge sehr hoch. Hinweis: Minijobs bis €556/Monat fallen nicht unter SK 6 — diese werden pauschal versteuert.',
      link: null, linkText: null
    };

    if (fs === 'ledig') {
      if (ae === 'ja') return {
        sk: 'Steuerklasse 2',
        text: 'Als Alleinerziehende/r mit Kind im Haushalt haben Sie Anspruch auf SK 2 — inklusive €4.260 Entlastungsbetrag (2026, erstes Kind) + €240 je weiterem Kind. Bei 30% Grenzsteuersatz entspricht das ca. €106 mehr Netto/Monat. Wichtig: SK 2 wird nicht automatisch zugeteilt — bitte aktiv beim Finanzamt beantragen!',
        link: '#steuerklasse-2-beantragen',
        linkText: 'So beantragen Sie SK 2 →'
      };
      return {
        sk: 'Steuerklasse 1',
        text: 'Als ledige Person ohne Kinder sind Sie in SK 1 — die Standardklasse für Singles. Es gibt nichts zu beantragen. Der Grundfreibetrag 2026 beträgt €12.348 — auf diesen Betrag zahlen Sie 0% Einkommensteuer.',
        link: null, linkText: null
      };
    }

    if (fs === 'verwitwet') return {
      sk: 'SK 3 → danach SK 1',
      text: 'Im Todesjahr und im gesamten Folgejahr gilt noch SK 3 (Gnadensplitting, §38b Abs. 1 Nr. 3b EStG) — eine Übergangsfrist zur finanziellen Stabilisierung. Ab dem übernächsten Jahr wechseln Sie automatisch in SK 1. Beispiel: Tod im März 2025 → SK 3 gilt für 2025 und 2026 → ab Januar 2027 SK 1.',
      link: null, linkText: null
    };

    if (fs === 'geschieden') return {
      sk: 'Steuerklasse 1',
      text: 'Nach dauerhafter Trennung oder Scheidung werden Sie ab dem Folgejahr der Trennung in SK 1 eingestuft — nicht erst nach rechtskräftiger Scheidung. Im Trennungsjahr selbst darf SK III/V noch genutzt werden. Rechtsgrundlage: §38b Abs. 1 EStG — „nicht dauernd getrennt lebend".',
      link: null, linkText: null
    };

    if (fs === 'verheiratet') {
      var a = anteil;
      if (a >= 60 || a <= 40) return {
        sk: 'Steuerklasse 3 / 5',
        text: 'Die 60-40-Regel ist erfüllt: SK 3 erhöht das monatliche Netto des Hauptverdieners erheblich. Wichtig: Die Jahressteuerlast ist identisch zu SK 4/4 — SK 3/5 ist nur eine andere monatliche Vorauszahlung. Am Jahresende kommt eine Nachzahlung, da SK 3 zu wenig einbehält. Beide müssen eine Steuererklärung einreichen (Pflichtveranlagung, §46 EStG).',
        link: '/steuerklasse-3-5/',
        linkText: 'SK 3 und 5 im Detail — Rechner & Nachzahlung →'
      };
      if (a >= 45 && a <= 55) return {
        sk: 'Steuerklasse 4 / 4',
        text: 'Beide Partner verdienen ähnlich viel — SK 4/4 ist die fairste und unkomplizierteste Wahl. Kein Nachzahlungsrisiko, keine Pflicht zur gemeinsamen Steuererklärung. Die Jahressteuerlast ist identisch zu SK 3/5.',
        link: '/steuerklasse-3-5/',
        linkText: 'Vergleich SK 3/5 vs. 4/4 →'
      };
      return {
        sk: 'Steuerklasse 4 mit Faktor',
        text: 'Grenzbereich (40–60%): Das Faktorverfahren teilt den Splittingvorteil fair und proportional auf beide Partner auf — kein Partner zahlt unverhältnismäßig hohe Abzüge. Kaum Nachzahlung am Jahresende. Steuererklärung ist Pflicht (§46 EStG). Der Faktor wird bei größeren Einkommensänderungen neu beantragt.',
        link: '/steuerklasse-heirat/',
        linkText: 'Faktorverfahren im Detail →'
      };
    }

    return { sk: 'Steuerklasse 1', text: 'Standardsteuerklasse. §38b EStG.', link: null, linkText: null };
  }

  /* ── Run Finder ── */
  function runFinder(): void {
    var fsEl = document.querySelector<HTMLInputElement>('input[name="familienstand"]:checked');
    if (!fsEl) { alert('Bitte wählen Sie zuerst Ihren Familienstand aus.'); return; }

    var fs    = fsEl.value;
    var aeEl  = document.querySelector<HTMLInputElement>('input[name="alleinerziehend"]:checked');
    var ae    = aeEl ? aeEl.value : 'nein';
    var anteil = parseInt(slider.value);
    var zwEl  = document.querySelector<HTMLInputElement>('input[name="zweiterjob"]:checked');
    var zweit = zwEl ? zwEl.value : 'nein';

    var res = getSK(fs, ae, anteil, zweit);

    badge.textContent  = res.sk;
    reason.textContent = res.text;

    if (res.link) {
      ctaLink.href        = res.link;
      ctaLink.textContent = res.linkText;
      (ctaLink as HTMLElement).style.display = 'inline-block';
      ctaLink.classList.remove('hidden');
    } else {
      (ctaLink as HTMLElement).style.display = 'none';
      ctaLink.classList.add('hidden');
    }

    /* Share row */
    var shareUrl  = 'https://nettoklar.de/steuerklasse-finder/?' +
      new URLSearchParams({ fs, ae, anteil: String(anteil), zweit }).toString();
    var shareText = 'Meine Steuerklasse ist ' + res.sk + ' — NettoKlar Steuerklassen-Finder: ' + shareUrl;

    shareRow.innerHTML = '';

    var cpBtn = document.createElement('button');
    cpBtn.className   = 'preset-chip';
    cpBtn.textContent = '📋 Ergebnis kopieren';
    cpBtn.addEventListener('click', function () {
      navigator.clipboard.writeText(shareText).then(function () {
        cpBtn.textContent = '✓ Kopiert!';
        setTimeout(function () { cpBtn.textContent = '📋 Ergebnis kopieren'; }, 2000);
      });
    });

    var waLink        = document.createElement('a');
    waLink.href       = 'https://wa.me/?text=' + encodeURIComponent(shareText);
    waLink.target     = '_blank';
    waLink.rel        = 'noopener noreferrer';
    waLink.className  = 'preset-chip';
    waLink.textContent = '💬 WhatsApp teilen';

    shareRow.appendChild(cpBtn);
    shareRow.appendChild(waLink);
    (shareRow as HTMLElement).style.display = 'flex';
    shareRow.classList.remove('hidden');

    history.replaceState(null, '', '?' + new URLSearchParams({ fs, ae, anteil: String(anteil), zweit }).toString());

    resultBox.classList.remove('hidden');
    resultBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  btn.addEventListener('click', runFinder);

  /* ── Restore state from URL params ── */
  (function restoreFromUrl(): void {
    var p = new URLSearchParams(window.location.search);
    if (!p.get('fs')) return;

    var fsR = document.querySelector<HTMLInputElement>('input[name="familienstand"][value="' + p.get('fs') + '"]');
    if (fsR) { fsR.checked = true; showHideSteps(); }

    if (p.get('ae')) {
      var aeR = document.querySelector<HTMLInputElement>('input[name="alleinerziehend"][value="' + p.get('ae') + '"]');
      if (aeR) aeR.checked = true;
    }
    if (p.get('anteil')) {
      slider.value            = p.get('anteil')!;
      anteilDisp.textContent  = p.get('anteil') + '%';
      partnerDisp.textContent = (100 - parseInt(p.get('anteil')!)) + '%';
    }
    if (p.get('zweit')) {
      var zwR = document.querySelector<HTMLInputElement>('input[name="zweiterjob"][value="' + p.get('zweit') + '"]');
      if (zwR) zwR.checked = true;
    }
    runFinder();
  })();

  /* ── Embed modal ── */
  embedBtn.addEventListener('click', function () {
    (embedModal as HTMLElement).style.display = 'flex';
  });
  closeEmbed.addEventListener('click', function () {
    (embedModal as HTMLElement).style.display = 'none';
  });
  embedModal.addEventListener('click', function (e: Event) {
    if (e.target === embedModal) (embedModal as HTMLElement).style.display = 'none';
  });
  copyEmbed.addEventListener('click', function () {
    var code = document.getElementById('embed-code')!.textContent || '';
    navigator.clipboard.writeText(code.trim()).then(function () {
      (copyEmbed as HTMLButtonElement).textContent = '✓ Kopiert!';
      setTimeout(function () {
        (copyEmbed as HTMLButtonElement).textContent = 'Code kopieren';
      }, 2000);
    });
  });

  /* ── FAQ deep-link ── */
  function openFaqFromHash(): void {
    var hash = window.location.hash.slice(1);
    if (!hash) return;
    var target = document.getElementById(hash);
    if (target && target.tagName === 'DETAILS') {
      (target as HTMLDetailsElement).open = true;
      setTimeout(function () {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 80);
    }
  }
  window.addEventListener('DOMContentLoaded', openFaqFromHash);
  window.addEventListener('hashchange', openFaqFromHash);

})();
</script>