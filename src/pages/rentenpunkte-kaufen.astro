<script>
  // ── Constants (verified 2026) ──────────────────────────────
  const COST_PER_POINT = 9661.58;
  const RENTENWERT     = 42.52;  // Jul–Dec 2026

  function fmt(val: number): string {
    return val.toLocaleString('de-DE', { style: 'currency', currency: 'EUR' });
  }
  function r2(v: number): number { return Math.round(v * 100) / 100; }

  // Preset chips
  document.querySelectorAll<HTMLButtonElement>('.preset-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const input = document.getElementById(chip.dataset.target!) as HTMLInputElement;
      if (input) input.value = chip.dataset.val!;
    });
  });

  // Toggle rate buttons
  let selectedRate = 0.30;
  document.querySelectorAll<HTMLButtonElement>('.toggle-btn[data-rate]').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.toggle-btn[data-rate]').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedRate = parseFloat(btn.dataset.rate!);
      (document.getElementById('rk-steuer') as HTMLInputElement).value = String(selectedRate);
    });
  });

  // Calculate
  document.getElementById('rk-berechnen')?.addEventListener('click', () => {
    const alter       = parseInt((document.getElementById('rk-alter') as HTMLInputElement).value);
    const rentenalter = parseInt((document.getElementById('rk-rentenalter') as HTMLInputElement).value);
    const punkte      = parseInt((document.getElementById('rk-punkte') as HTMLInputElement).value);
    const steuer      = selectedRate;

    const warning = document.getElementById('rk-warning')!;
    const results = document.getElementById('rk-results')!;

    if (rentenalter - alter < 2) {
      warning.classList.remove('hidden');
      results.classList.add('hidden');
      return;
    }
    warning.classList.add('hidden');

    const totalBrutto  = r2(punkte * COST_PER_POINT);
    const taxSaving    = r2(totalBrutto * steuer);
    const totalNet     = r2(totalBrutto - taxSaving);
    const monthlyGain  = r2(punkte * RENTENWERT);
    const annualGain   = r2(monthlyGain * 12);
    const yearsBreak   = totalNet / annualGain;
    const breakEvenAge = Math.round(rentenalter + yearsBreak);

    (document.getElementById('rk-out-brutto') as HTMLElement).textContent      = fmt(totalBrutto);
    (document.getElementById('rk-out-steuer') as HTMLElement).textContent      = '−' + fmt(taxSaving);
    (document.getElementById('rk-out-netto') as HTMLElement).textContent       = fmt(totalNet);
    (document.getElementById('rk-out-rente') as HTMLElement).textContent       = '+' + fmt(monthlyGain) + '/Monat';
    (document.getElementById('rk-out-rente-annual') as HTMLElement).textContent= '+' + fmt(annualGain) + '/Jahr';
    (document.getElementById('rk-out-breakeven') as HTMLElement).textContent   = 'Alter ' + breakEvenAge;

    const verdictBadge = document.getElementById('rk-out-verdict-badge')!;
    const verdictText  = document.getElementById('rk-out-verdict-text')!;
    if (breakEvenAge <= 82) {
      verdictBadge.textContent = '✅ Lohnt sich';
      verdictBadge.style.background = 'var(--color-net)';
      verdictText.textContent = `Break-Even Alter ${breakEvenAge} liegt innerhalb der durchschnittlichen Lebenserwartung.`;
    } else if (breakEvenAge <= 86) {
      verdictBadge.textContent = '⚠️ Grenzfall';
      verdictBadge.style.background = 'var(--color-deduction)';
      verdictText.textContent = `Break-Even Alter ${breakEvenAge} liegt im Bereich der weiblichen Lebenserwartung. Mit Steuerbonus oft lohnenswert.`;
    } else {
      verdictBadge.textContent = '❌ Eher nicht';
      verdictBadge.style.background = '#9e3a3a';
      verdictText.textContent = `Break-Even Alter ${breakEvenAge} liegt jenseits der durchschnittlichen Lebenserwartung. Steuerbonus prüfen.`;
    }

    results.classList.remove('hidden');
    results.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  // Auto-open <details> FAQ item if its ID matches the URL hash on load or navigation
  function openFaqFromHash() {
    const hash = window.location.hash.slice(1); // strip the #
    if (!hash) return;
    const target = document.getElementById(hash);
    if (target && target.tagName === 'DETAILS') {
      target.open = true;
      // Small delay so scroll-margin-top kicks in after open
      setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 80);
    }
  }

  // On initial load
  window.addEventListener('DOMContentLoaded', openFaqFromHash);

  // On hash change (user clicks a pill link while already on the page)
  window.addEventListener('hashchange', openFaqFromHash);
</script>