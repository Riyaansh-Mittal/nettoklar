---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://nettoklar.de/rentenpunkte-kaufen/#webpage",
    "url": "https://nettoklar.de/rentenpunkte-kaufen/",
    "name": "Rentenpunkte kaufen 2026: Kosten, Rechner & lohnt sich?",
    "headline": "Rentenpunkte kaufen 2026 – Was kostet ein Punkt & lohnt es sich wirklich?",
    "datePublished": "2026-04-25",
    "dateModified": "2026-05-05",
    "inLanguage": "de-DE",
    "isPartOf": { "@id": "https://nettoklar.de/#website" },
    "breadcrumb": { "@id": "https://nettoklar.de/rentenpunkte-kaufen/#breadcrumb" },
    "author": {
      "@type": "Person",
      "name": "Riyaansh Mittal",
      "url": "https://nettoklar.de/ueber-uns/"
    },
    "publisher": {
      "@type": "Organization",
      "name": "NettoKlar",
      "@id": "https://nettoklar.de/#organization",
      "url": "https://nettoklar.de/"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "@id": "https://nettoklar.de/rentenpunkte-kaufen/#breadcrumb",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "NettoKlar", "item": "https://nettoklar.de/" },
      { "@type": "ListItem", "position": 2, "name": "Rentenpunkte kaufen 2026", "item": "https://nettoklar.de/rentenpunkte-kaufen/" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": "https://nettoklar.de/rentenpunkte-kaufen/#faq",
    "dateModified": "2026-05-05",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Was kostet ein Rentenpunkt 2026 beim Kauf?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der Kauf eines Rentenpunktes kostet 2026 genau 9.661,58 Euro (51.944 × 18,6 %). Nach Steuerbonus als Sonderausgaben sinken die effektiven Kosten auf ca. 5.600–7.200 Euro je nach Grenzsteuersatz."
        }
      },
      {
        "@type": "Question",
        "name": "Lohnt sich der Kauf von Rentenpunkten?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der Break-even liegt bei ca. Alter 80 (Rente ab 67, Steuer 30 %). Für Personen mit Grenzsteuersatz ≥42% und mindestens 10 Jahren bis zur Rente lohnt es sich meistens. Für Personen mit unter 42% Steuersatz oder weniger als 8 Jahren bis Rente ist es kritisch zu prüfen."
        }
      },
      {
        "@type": "Question",
        "name": "Wie viele Rentenpunkte kann man kaufen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Es gibt keine Höchstzahl. Die jährliche Einzahlung ist auf die BBG (€101.400 in 2026) begrenzt. Teilzahlungen über mehrere Jahre sind möglich."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist das Formular V0800?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Das Formular V0800 ist der offizielle DRV-Antrag für freiwillige Rentenbeiträge. Kostenlos auf drv.de als PDF verfügbar oder per Post erhältlich."
        }
      },
      {
        "@type": "Question",
        "name": "Wer darf keine Rentenpunkte kaufen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nicht berechtigt: bereits Rentenbeziehende, Personen in den letzten 24 Monaten vor Renteneintritt arbeitslos, Beamte außerhalb der GRV (§ 187a SGB VI)."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "@id": "https://nettoklar.de/rentenpunkte-kaufen/#app",
    "name": "Rentenpunkte Kauf-Rechner 2026",
    "url": "https://nettoklar.de/rentenpunkte-kaufen/",
    "description": "Berechnen Sie Ihre persönliche Rendite, Steuerersparnis und Break-Even-Alter beim Kauf von Rentenpunkten 2026.",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "browserRequirements": "Requires JavaScript",
    "inLanguage": "de-DE",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" }
  },
  {
    "@context": "https://schema.org",
    "@type": "SpeakableSpecification",
    "@id": "https://nettoklar.de/rentenpunkte-kaufen/#speakable",
    "cssSelector": [".direct-answer", ".fact-strip", "h1"]
  }
];
---

<BaseLayout
  title="Rentenpunkte kaufen 2026: Kosten, Rechner & lohnt sich?"
  description="1 Rentenpunkt kaufen kostet 2026 ca. €9.661. Rechner zeigt Break-Even & Steuerersparnis. Formular V0800 erklärt. Lohnt es sich wirklich?"
  schema={schema}
>
  <a href="#main-content" class="sr-only">Zum Inhalt springen</a>

  <main id="main-content">
    <div class="page-wrapper">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
          <li><a href="/">NettoKlar</a></li>
          <li>Rentenpunkte kaufen 2026</li>
        </ol>
      </nav>

      <article>

        <!-- Article Header -->
        <header class="article-header">
          <h1>Rentenpunkte kaufen 2026 – Was kostet ein Punkt &amp; lohnt es sich wirklich?</h1>
          <div class="author-byline">
            <span>Von <strong>Riyaansh Mittal</strong></span>
            <span class="byline-sep">·</span>
            <span>Aktualisiert: Mai 2026</span>
            <span class="byline-sep">·</span>
            <span class="freshness-badge">✓ Geprüft 2026</span>
          </div>
        </header>

        <!-- Direct Answer (above the fold — cited by LLMs) -->
        <p class="direct-answer">
          Ein Rentenpunkt kostet 2026 genau <strong>€9.661,58</strong> (§ 187a SGB VI).
          Ab Juli 2026 bringt er <strong>€42,52/Monat</strong> mehr Rente.
          Break-even bei Grenzsteuersatz 30%: <strong>ca. Alter 80</strong>.
          Für Personen mit ≥42% Steuersatz und ≥10 Jahren bis zur Rente lohnt es sich meistens.
        </p>

        <!-- FAQ Preview Strip -->
        <div class="faq-preview-strip">
          <span class="faq-preview-label">Häufige Fragen:</span>
          <a href="#faq-kosten">Was kostet ein Rentenpunkt?</a>
          <a href="#faq-lohnt">Lohnt sich der Kauf?</a>
          <a href="#faq-anzahl">Wie viele kann ich kaufen?</a>
          <a href="#faq-v0800">Formular V0800?</a>
          <a href="#faq-nicht">Wer darf keine Rentenpunkte kaufen?</a>
          <a href="#faq" class="faq-preview-all">Alle FAQs →</a>
        </div>

        <!-- Jump Nav -->
        <nav class="article-jump-nav" aria-label="Seitennavigation">
          <span class="jump-nav-label">Auf dieser Seite:</span>
          <a href="#kosten">Kosten</a>
          <a href="#lohnt-sich">Lohnt es sich?</a>
          <a href="#rechner">Rechner</a>
          <a href="#wer-darf">Wer darf?</a>
          <a href="#steuer">Steuer</a>
          <a href="#tabelle">Tabelle</a>
          <a href="#v0800">Formular V0800</a>
          <a href="#faq">FAQ</a>
        </nav>

        <!-- Fact Strip -->
        <dl class="fact-strip">
          <div class="fact-item">
            <dt>Kosten pro Punkt (2026)</dt>
            <dd>€9.661,58</dd>
          </div>
          <div class="fact-item">
            <dt>Rentenwert ab Jul 2026</dt>
            <dd>€42,52 / Monat</dd>
          </div>
          <div class="fact-item">
            <dt>Rechtsgrundlage</dt>
            <dd>§ 187a SGB VI</dd>
          </div>
          <div class="fact-item">
            <dt>Break-Even (30% Steuer)</dt>
            <dd>ca. Alter 80</dd>
          </div>
          <div class="fact-item">
            <dt>BBG 2026</dt>
            <dd>€101.400 / Jahr</dd>
          </div>
          <div class="fact-item">
            <dt>Steuerlich absetzbar</dt>
            <dd>Ja — Sonderausgaben</dd>
          </div>
        </dl>

        <div class="article-body">

          <!-- ══ H2 1: Kosten ══ -->
          <section id="kosten" class="anchor-section">
            <h2>Was kostet ein Rentenpunkt 2026?</h2>
            <p>
              Die Kosten ergeben sich aus dem vorläufigen Durchschnittsentgelt 2026 multipliziert mit dem
              Rentenversicherungsbeitragssatz: <strong>€51.944 × 18,6% = €9.661,58 pro Punkt</strong>.
              Der exakte Betrag wird von der DRV auf Anfrage per <a href="#v0800">Formular V0800</a> bestätigt.
            </p>

            <div class="table-scroll">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Kennzahl</th>
                    <th>Wert 2026</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="highlight-row">
                    <td><strong>Kosten pro Rentenpunkt</strong></td>
                    <td><strong>€9.661,58</strong></td>
                  </tr>
                  <tr>
                    <td>Vorläufiges Durchschnittsentgelt (DRV)</td>
                    <td>€51.944 / Jahr</td>
                  </tr>
                  <tr>
                    <td>Rentenwert Jan–Jun 2026</td>
                    <td>€40,79 / Monat</td>
                  </tr>
                  <tr>
                    <td>Rentenwert ab Jul 2026</td>
                    <td>€42,52 / Monat</td>
                  </tr>
                  <tr>
                    <td>Maximale Einzahlung pro Jahr</td>
                    <td>Bis BBG (€101.400)</td>
                  </tr>
                  <tr>
                    <td>Amortisationsdauer (ohne Steuer)</td>
                    <td>~18,9 Jahre</td>
                  </tr>
                  <tr>
                    <td>Amortisationsdauer (nach Steuer 30%)</td>
                    <td>~13,2 Jahre (ab Alter 67 ≈ Alter 80)</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="inline-link-callout">
              <span>→</span>
              <span>Zum Vergleich: <a href="/wert-der-rentenpunkte/">Was ist ein Rentenpunkt 2026 wert?</a></span>
            </div>
          </section>

          <!-- ══ H2 2: Lohnt es sich — Verdict Block ══ -->
          <section id="lohnt-sich" class="anchor-section">
            <h2>Lohnt es sich, Rentenpunkte zu kaufen? – Unser Fazit</h2>

            <!-- Verdict box — must appear in first scroll per document spec -->
            <div class="summary-card">
              <h2>Schnell-Fazit für Ihre Situation</h2>
              <div class="calc-grid-2">
                <div>
                  <p style="margin-bottom: var(--space-2)"><strong style="color: var(--color-net)">✅ Lohnt sich — wenn:</strong></p>
                  <ul class="content-list">
                    <li>Grenzsteuersatz ≥ 42%</li>
                    <li>Mindestens 10 Jahre bis zur Rente</li>
                    <li>Gute Gesundheit / hohe Lebenserwartung</li>
                    <li>Frau (statistisch höhere Lebenserwartung)</li>
                  </ul>
                </div>
                <div>
                  <p style="margin-bottom: var(--space-2)"><strong style="color: var(--color-deduction)">❌ Lohnt sich kaum — wenn:</strong></p>
                  <ul class="content-list">
                    <li>Steuersatz unter 42%</li>
                    <li>Weniger als 8 Jahre bis zur Rente</li>
                    <li>Vorerkrankungen / geringere Lebenserwartung</li>
                    <li>Bereits in den letzten 24 Monaten vor Rente</li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Break-Even Tabelle (static — for LLM citation) -->
            <div class="table-scroll">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Grenzsteuersatz</th>
                    <th>Break-Even-Zeitraum</th>
                    <th>Empfehlung</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="highlight-row">
                    <td><strong>42%</strong></td>
                    <td><strong>ca. 12 Jahre (Alter ~79)</strong></td>
                    <td><strong>Lohnt sich bei langem Rentenhorizont</strong></td>
                  </tr>
                  <tr>
                    <td>30%</td>
                    <td>ca. 13 Jahre (Alter ~80)</td>
                    <td>Grenzfall — Lebenserwartung entscheidend</td>
                  </tr>
                  <tr>
                    <td>25%</td>
                    <td>ca. 14 Jahre (Alter ~81)</td>
                    <td>Nur bei sehr langer Lebenserwartung</td>
                  </tr>
                  <tr>
                    <td>20%</td>
                    <td>ca. 17 Jahre (Alter ~84)</td>
                    <td>Kaum empfehlenswert</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p style="font-size: var(--text-xs); color: var(--color-text-muted)">
              Basis: Renteneintritt 67, Rentenwert €42,52/Monat (ab Jul 2026). Kein Steuerberatungsersatz.
            </p>

            <!-- Pro/Con table -->
            <h3 style="margin-top: var(--space-8); margin-bottom: var(--space-4); font-size: var(--text-lg)">Vor- und Nachteile – Rentenpunkte kaufen</h3>
            <div class="table-scroll">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>✅ Vorteile</th>
                    <th>❌ Nachteile</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>Steuerlich absetzbar (Sonderausgaben, bis €29.344)</td>
                    <td>Hoher Einmalbetrag (~€9.662/Punkt)</td>
                  </tr>
                  <tr>
                    <td>Lebenslange, inflationsgesicherte Rente</td>
                    <td>Break-even erst nach ~12–17 Jahren</td>
                  </tr>
                  <tr>
                    <td>Kein Marktrisiko (gesetzl. Rentenversicherung)</td>
                    <td>Kapital nicht vererbbar (kein Todesfallschutz)</td>
                  </tr>
                  <tr>
                    <td>Schutz vor Langlebigkeitsrisiko</td>
                    <td>Rente voll steuerpflichtig im Alter</td>
                  </tr>
                  <tr>
                    <td>Einfache Abwicklung (Formular V0800)</td>
                    <td>Nicht möglich in den letzten 2 Jahren vor Rente</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <!-- ══ H2 3: Rechner ══ -->
          <section id="rechner" class="anchor-section">
            <h2>Lohnt sich Rentenpunkte kaufen? — Rechner 2026</h2>

            <div class="calculator-card">
              <h2>Rentenpunkte Kauf-Rechner</h2>
              <p class="calc-subtitle">
                Berechnen Sie Ihre persönliche Rendite, Steuerersparnis und Break-Even-Alter.
              </p>

              <!-- Row 1: Alter & Rentenalter -->
              <div class="calc-grid-2">
                <div class="calc-field-group">
                  <label class="calc-label" for="rk-alter">Ihr aktuelles Alter</label>
                  <div class="input-euro-wrap">
                    <input class="calc-input" type="number" id="rk-alter" min="35" max="65" value="50" />
                  </div>
                </div>
                <div class="calc-field-group">
                  <label class="calc-label" for="rk-rentenalter">Geplantes Rentenalter</label>
                  <div class="input-euro-wrap">
                    <input class="calc-input" type="number" id="rk-rentenalter" min="60" max="70" value="67" />
                  </div>
                  <p class="calc-hint">Regelrentenalter 2026: 67 Jahre</p>
                </div>
              </div>

              <!-- Row 2: Punkte & Steuer -->
              <div class="calc-grid-2">
                <div class="calc-field-group">
                  <label class="calc-label" for="rk-punkte">Anzahl Punkte kaufen</label>
                  <div class="input-euro-wrap">
                    <input class="calc-input" type="number" id="rk-punkte" min="1" max="20" value="3" />
                  </div>
                  <div class="preset-row">
                    <button class="preset-chip" data-target="rk-punkte" data-val="1">1</button>
                    <button class="preset-chip" data-target="rk-punkte" data-val="3">3</button>
                    <button class="preset-chip" data-target="rk-punkte" data-val="5">5</button>
                    <button class="preset-chip" data-target="rk-punkte" data-val="10">10</button>
                  </div>
                </div>
                <div class="calc-field-group">
                  <label class="calc-label" for="rk-steuer">Ihr Grenzsteuersatz</label>
                  <div class="toggle-group">
                    <button class="toggle-btn" data-rate="0.25">25%</button>
                    <button class="toggle-btn active" data-rate="0.30">30%</button>
                    <button class="toggle-btn" data-rate="0.35">35%</button>
                    <button class="toggle-btn" data-rate="0.42">42%</button>
                  </div>
                  <input type="hidden" id="rk-steuer" value="0.30" />
                </div>
              </div>

              <button id="rk-berechnen" class="btn-primary btn-full">
                Jetzt berechnen — Lohnt sich der Kauf für mich?
              </button>

              <!-- Warning -->
              <div id="rk-warning" class="nachzahlung-box hidden" role="alert">
                <p class="nachzahlung-label">⚠️ Achtung — Nicht berechtigt</p>
                <p class="nachzahlung-text">
                  Innerhalb der letzten 2 Jahre vor Renteneintritt ist der Kauf von
                  Rentenpunkten nicht mehr möglich (§ 187a SGB VI).
                </p>
              </div>

              <!-- Results -->
              <div id="rk-results" class="result-block hidden" aria-live="polite">
                <div class="calc-result-grid">
                  <div class="calc-result-item">
                    <span class="result-label">Gesamtkosten (brutto)</span>
                    <span class="result-badge" id="rk-out-brutto" style="background:var(--color-gross)"></span>
                  </div>
                  <div class="calc-result-item">
                    <span class="result-label">Steuerersparnis</span>
                    <span class="result-badge" id="rk-out-steuer" style="background:var(--color-deduction)"></span>
                  </div>
                  <div class="calc-result-item highlight-result">
                    <span class="result-label">Effektive Kosten nach Steuer</span>
                    <span class="result-badge" id="rk-out-netto" style="background:var(--color-net)"></span>
                  </div>
                  <div class="calc-result-item">
                    <span class="result-label">Monatliche Rentenerhöhung</span>
                    <span class="result-badge" id="rk-out-rente"></span>
                  </div>
                  <div class="calc-result-item">
                    <span class="result-label">Jährliche Rentenerhöhung</span>
                    <span class="result-badge" id="rk-out-rente-annual" style="background:var(--color-text-muted)"></span>
                  </div>
                  <div class="calc-result-item">
                    <span class="result-label">Break-Even Alter</span>
                    <span class="result-badge" id="rk-out-breakeven" style="background:var(--color-text)"></span>
                  </div>
                </div>

                <!-- Verdict -->
                <div id="rk-verdict" class="result-block">
                  <div class="result-top-row">
                    <span class="result-badge" id="rk-out-verdict-badge"></span>
                    <p class="result-reason" id="rk-out-verdict-text"></p>
                  </div>
                </div>
              </div>

              <p style="margin-top: var(--space-4); font-size: var(--text-xs); color: var(--color-text-muted)">
                Basis: Rentenwert €42,52/Monat (ab Jul 2026). § 187a SGB VI. Rechtsgrundlage SVRVG 2026.
                Kein Steuerberatungsersatz.
              </p>
            </div>
          </section>

          <!-- ══ H2 4: Wer darf ══ -->
          <section id="wer-darf" class="anchor-section">
            <h2>Wer darf Rentenpunkte kaufen?</h2>

            <div class="calc-grid-2">
              <div>
                <p style="margin-bottom: var(--space-2)"><strong style="color:var(--color-net)">✅ Berechtigt</strong></p>
                <ul class="content-list">
                  <li>Pflichtversicherte in der GRV</li>
                  <li>Freiwillig Versicherte</li>
                  <li>Beamte (eingeschränkt, je nach Versicherungsart)</li>
                  <li>Personen in Elternzeit</li>
                </ul>
              </div>
              <div>
                <p style="margin-bottom: var(--space-2)"><strong style="color:var(--color-deduction)">❌ Nicht berechtigt</strong></p>
                <ul class="content-list">
                  <li>Bereits Rentenbeziehende</li>
                  <li>In den letzten 24 Monaten vor Renteneintritt arbeitslos</li>
                  <li>Beamte außerhalb der GRV</li>
                </ul>
              </div>
            </div>
          </section>

          <!-- ══ H2 5: Steuer ══ -->
          <section id="steuer" class="anchor-section">
            <h2>Steuerlicher Vorteil beim Rentenpunkte kaufen</h2>
            <p>
              Die Einzahlung ist als <strong>Sonderausgabe</strong> steuerlich absetzbar —
              bis zu €29.344/Jahr (Singles 2026).
            </p>

            <div class="table-scroll">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Grenzsteuersatz</th>
                    <th>Kosten brutto</th>
                    <th>Steuerersparnis</th>
                    <th>Effektive Kosten</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>25%</td>
                    <td>€9.661,58</td>
                    <td>−€2.415,40</td>
                    <td>€7.246,19</td>
                  </tr>
                  <tr>
                    <td>30%</td>
                    <td>€9.661,58</td>
                    <td>−€2.898,47</td>
                    <td>€6.763,11</td>
                  </tr>
                  <tr>
                    <td>35%</td>
                    <td>€9.661,58</td>
                    <td>−€3.381,55</td>
                    <td>€6.280,03</td>
                  </tr>
                  <tr class="highlight-row">
                    <td>42%</td>
                    <td>€9.661,58</td>
                    <td><strong>−€4.057,86</strong></td>
                    <td><strong>€5.603,72</strong></td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <!-- ══ H2 6: Tabelle ══ -->
          <section id="tabelle" class="anchor-section">
            <h2>Rentenpunkte kaufen — Tabelle: Kosten und Break-Even</h2>

            <div class="table-scroll">
              <table class="data-table">
                <thead>
                  <tr>
                    <th>Punkte</th>
                    <th>Kosten brutto</th>
                    <th>Kosten netto (30%)</th>
                    <th>Monatl. Rentenplus</th>
                    <th>Break-Even ab Rente 67</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>1</td>
                    <td>€9.662</td>
                    <td>~€6.763</td>
                    <td>+€42,52</td>
                    <td>~Alter 80</td>
                  </tr>
                  <tr>
                    <td>3</td>
                    <td>€28.985</td>
                    <td>~€20.290</td>
                    <td>+€127,56</td>
                    <td>~Alter 80</td>
                  </tr>
                  <tr>
                    <td>5</td>
                    <td>€48.308</td>
                    <td>~€33.816</td>
                    <td>+€212,60</td>
