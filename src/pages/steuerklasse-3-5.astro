<script>
  // ── Preset chips ───────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.preset-chip[data-a]').forEach(chip => {
    chip.addEventListener('click', () => {
      const a = document.getElementById('brutto-a') as HTMLInputElement;
      const b = document.getElementById('brutto-b') as HTMLInputElement;
      a.value = chip.dataset.a!;
      b.value = chip.dataset.b!;
      calculate();
    });
  });

  document.getElementById('brutto-a')?.addEventListener('input', calculate);
  document.getElementById('brutto-b')?.addEventListener('input', calculate);

  function fmt(n: number): string {
    return n.toLocaleString('de-DE', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
  }

  function calculate(): void {
    const a = parseFloat((document.getElementById('brutto-a') as HTMLInputElement).value) || 0;
    const b = parseFloat((document.getElementById('brutto-b') as HTMLInputElement).value) || 0;
    const result   = document.getElementById('sk35-result')!;
    const badge    = document.getElementById('sk35-badge')!;
    const reason   = document.getElementById('sk35-reason')!;
    const ratioEl  = document.getElementById('sk35-ratio')!;
    const nachBox  = document.getElementById('sk35-nachzahlung-box')!;
    const nachTxt  = document.getElementById('sk35-nachzahlung-text')!;

    if (a <= 0 && b <= 0) { result.classList.add('hidden'); return; }

    const combined = a + b;
    const ratioA   = combined > 0 ? a / combined : 0.5;
    const higher   = ratioA >= 0.5 ? 'Partner A' : 'Partner B';
    const highPct  = Math.round(Math.max(ratioA, 1 - ratioA) * 100);

    let empfehlung: string, reasonText: string, showNach = false;

    if (ratioA >= 0.60 || ratioA <= 0.40) {
      empfehlung = 'SK 3 / SK 5';
      reasonText = `${higher} verdient ${highPct}% — die 60-40-Regel ist erfüllt. SK 3/5 erhöht das monatliche Netto des Hauptverdieners. Am Jahresende fällt eine Nachzahlung an (Schätzung unten).`;
      showNach = true;
      badge.style.background = 'var(--color-primary)';
    } else if (ratioA >= 0.45 && ratioA <= 0.55) {
      empfehlung = 'SK 4 / SK 4';
      reasonText = 'Beide Partner verdienen ähnlich — SK 4/4 ist die fairste Wahl. Kein Nachzahlungsrisiko, keine gemeinsame Steuererklärungspflicht.';
      badge.style.background = 'var(--color-net)';
    } else {
      empfehlung = 'SK 4 mit Faktor';
      reasonText = 'Grenzbereich (40–60%): Das Faktorverfahren verteilt monatliche Abzüge am präzisesten und vermeidet Nachzahlung.';
      badge.style.background = 'var(--color-deduction)';
    }

    badge.textContent = empfehlung;
    reason.textContent = reasonText;
    ratioEl.textContent = `Partner A: ${Math.round(ratioA * 100)}% · Partner B: ${Math.round((1 - ratioA) * 100)}% des gemeinsamen Einkommens`;

    if (showNach) {
      const annualDiff = Math.abs(a - b) * 12;
      const estNachzahlung = Math.round(annualDiff * 0.04);
      nachTxt.textContent = `Geschätzte Nachzahlung: ca. ${fmt(estNachzahlung)} / Jahr (Richtwert, abhängig von Sonderausgaben).`;
      nachBox.classList.remove('hidden');
    } else {
      nachBox.classList.add('hidden');
    }

    result.classList.remove('hidden');
  }

  // ── Auto-open <details> FAQ if ID matches URL hash ─────────
  function openFaqFromHash(): void {
    const hash = window.location.hash.slice(1);
    if (!hash) return;
    const target = document.getElementById(hash);
    if (target && target.tagName === 'DETAILS') {
      (target as HTMLDetailsElement).open = true;
      setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'start' }), 80);
    }
  }
  window.addEventListener('DOMContentLoaded', openFaqFromHash);
  window.addEventListener('hashchange', openFaqFromHash);
</script>