        </div>

      </article>
    </div>
  </main>
</BaseLayout>

<script>
// ══════════════════════════════════════════════════════════════
// GLOBAL CONSTANTS — 2026 (verified)
// ══════════════════════════════════════════════════════════════
const BBG_KV_PV     = 5812.50;   // €69,750/year ✅
const BBG_RV_AV     = 8450.00;   // €101,400/year ✅
const KV_TOTAL_AN   = 0.0875;    // 8.75% (7.3% + 1.45% avg Zusatzbeitrag 2.9%) ✅
const PV_WITH_CHILD = 0.0180;
const PV_NO_CHILD   = 0.0210;
const RV            = 0.0930;
const AV            = 0.0130;
const GFB           = 12348;
const GFB_DOUBLE    = 24696;
const SOLI_THRESHOLD= 20350;    // annual Lohnsteuer 2026 ✅ corrected from 18130
const SOLI_RATE     = 0.055;

function fmt(v: number): string {
  return v.toLocaleString('de-DE', { style: 'currency', currency: 'EUR' });
}
function r2(v: number): number { return Math.round(v * 100) / 100; }

// §32a EStG 2026 — BGBl. 2024 I Nr. 449 ✅
function calcEst(zvE: number): number {
  zvE = Math.floor(zvE);
  if (zvE <= 12348) return 0;
  if (zvE <= 17799) {
    const y = (zvE - 12348) / 10000;
    return Math.round((914.51 * y + 1400) * y);
  }
  if (zvE <= 69878) {
    const z = (zvE - 17799) / 10000;
    return Math.round((173.10 * z + 2397) * z + 1034.87);
  }
  if (zvE <= 277825) return Math.round(0.42 * zvE - 10911.92);
  return Math.round(0.45 * zvE - 19246.22);
}

function calcNetto(brutto: number, sk: number, kircheState: string, kinder: boolean) {
  const bKV = Math.min(brutto, BBG_KV_PV);
  const bRV = Math.min(brutto, BBG_RV_AV);
  const kv  = r2(bKV * KV_TOTAL_AN);
  const pv  = r2(bKV * (kinder ? PV_WITH_CHILD : PV_NO_CHILD));
  const rv  = r2(bRV * RV);
  const av  = r2(bRV * AV);
  const sv  = r2(kv + pv + rv + av);

  let fb = 0;
  if (sk === 3) fb = GFB_DOUBLE;
  else if (sk === 2) fb = GFB + 4260;
  else if (sk === 1 || sk === 4) fb = GFB;

  const zvE      = Math.max(0, brutto * 12 - sv * 12 - fb);
  const jLst     = calcEst(zvE);
  const mLst     = r2(jLst / 12);
  const soli     = jLst > SOLI_THRESHOLD ? r2(mLst * SOLI_RATE) : 0;
  let kirche     = 0;
  if (kircheState === 'ja')   kirche = r2(mLst * 0.09);
  if (kircheState === 'bybw') kirche = r2(mLst * 0.08);
  const netto    = r2(brutto - sv - mLst - soli - kirche);
  return { kv, pv, rv, av, mLst, soli, kirche, netto };
}

// ── TVöD Bund 2026 ────────────────────────────────────────────
// ⚠️ DEVELOPER: verify at oeffentlicher-dienst.de after 1. May 2026
const TVOED_BUND: Record<string, number[]> = {
  "EG 1":  [2300,2369,2440,2510,2554,2600],
  "EG 2":  [2432,2512,2620,2730,2810,2892],
  "EG 3":  [2554,2633,2751,2870,2950,3021],
  "EG 4":  [2665,2751,2880,3008,3094,3171],
  "EG 5":  [2760,2860,3000,3143,3240,3330],
  "EG 6":  [2860,2975,3122,3270,3386,3570],
  "EG 7":  [3003,3122,3280,3437,3561,3680],
  "EG 8":  [3143,3270,3437,3602,3730,3858],
  "EG 9a": [3448,3577,3748,3918,4066,4213],
  "EG 9b": [3622,3776,3960,4143,4295,4447],
  "EG 10": [3822,3999,4207,4415,4591,4768],
  "EG 11": [4032,4207,4454,4700,4876,5051],
  "EG 12": [4560,4769,5051,5333,5545,5757],
  "EG 13": [5003,5258,5572,5888,6143,6396],
  "EG 14": [5572,5856,6207,6557,6840,7122],
  "EG 15": [6442,6762,7162,7562,7882,8200],
};
const TVOED_VKA: Record<string, number[]> = Object.fromEntries(
  Object.entries(TVOED_BUND).map(([k, v]) => [k, v.map(x => Math.round(x * 1.01))])
);
const TVOED_SUE: Record<string, number[]> = {
  "S 2":  [2508,2608,2733,2852,2946,3031],
  "S 3":  [2636,2742,2876,3009,3113,3209],
  "S 4":  [2771,2885,3028,3171,3283,3387],
  "S 6":  [2946,3069,3225,3381,3504,3619],
  "S 7":  [3087,3220,3390,3559,3694,3819],
  "S 8a": [3225,3367,3550,3732,3878,4014],
  "S 8b": [3381,3532,3726,3919,4072,4215],
  "S 9":  [3559,3722,3933,4143,4305,4458],
  "S 11": [3732,3912,4143,4374,4551,4718],
  "S 12": [3978,4172,4423,4675,4866,5048],
  "S 13": [4143,4351,4620,4889,5095,5291],
  "S 14": [4374,4597,4882,5168,5390,5602],
  "S 15": [4675,4921,5233,5545,5793,6030],
  "S 16": [4889,5148,5482,5817,6083,6338],
  "S 17": [5233,5513,5872,6230,6516,6792],
  "S 18": [5545,5845,6233,6622,6927,7221],
};

// ── Populate selects ──────────────────────────────────────────
function populateSelect(id: string, keys: string[], def = 4) {
  const el = document.getElementById(id) as HTMLSelectElement;
  if (!el) return;
  keys.forEach((k, i) => {
    const o = document.createElement('option');
    o.value = k; o.textContent = k;
    if (i === def) o.selected = true;
    el.appendChild(o);
  });
}
populateSelect('t1-eg', Object.keys(TVOED_BUND), 5);
populateSelect('t2-sg', Object.keys(TVOED_SUE), 4);

// ── Render Entgelttabelle ─────────────────────────────────────
let currentTableData = TVOED_BUND;
function renderTable(data: Record<string, number[]>) {
  currentTableData = data;
  const tbody = document.getElementById('tvoed-tbody')!;
  tbody.innerHTML = '';
  for (const [eg, s] of Object.entries(data)) {
    const tr = document.createElement('tr');
    tr.innerHTML = `<td><strong>${eg}</strong></td>` + s.map(v => `<td>${fmt(v)}</td>`).join('');
    tbody.appendChild(tr);
  }
}
renderTable(TVOED_BUND);

// Table toggle
[['tab-bund', TVOED_BUND], ['tab-vka', TVOED_VKA], ['tab-sue', TVOED_SUE]].forEach(([id, data]) => {
  document.getElementById(id as string)?.addEventListener('click', () => {
    ['tab-bund','tab-vka','tab-sue'].forEach(b => document.getElementById(b)?.classList.remove('active'));
    document.getElementById(id as string)?.classList.add('active');
    renderTable(data as Record<string, number[]>);
  });
});

// ── Calc tab switch ───────────────────────────────────────────
document.getElementById('ctab-bund')?.addEventListener('click', () => {
  document.getElementById('ctab-bund')!.classList.add('active');
  document.getElementById('ctab-bund')!.setAttribute('aria-selected', 'true');
  document.getElementById('ctab-sue')!.classList.remove('active');
  document.getElementById('ctab-sue')!.setAttribute('aria-selected', 'false');
  document.getElementById('cpanel-bund')!.classList.remove('hidden');
  document.getElementById('cpanel-sue')!.classList.add('hidden');
});
document.getElementById('ctab-sue')?.addEventListener('click', () => {
  document.getElementById('ctab-sue')!.classList.add('active');
  document.getElementById('ctab-sue')!.setAttribute('aria-selected', 'true');
  document.getElementById('ctab-bund')!.classList.remove('active');
  document.getElementById('ctab-bund')!.setAttribute('aria-selected', 'false');
  document.getElementById('cpanel-sue')!.classList.remove('hidden');
  document.getElementById('cpanel-bund')!.classList.add('hidden');
});

// ── Generic toggle helpers ────────────────────────────────────
function makeToggleGroup(selector: string, hiddenId: string) {
  document.querySelectorAll<HTMLButtonElement>(selector).forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll(selector).forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      (document.getElementById(hiddenId) as HTMLInputElement).value =
        btn.dataset.sk ?? btn.dataset.sk2 ?? btn.dataset.zulage ?? '1';
    });
  });
}
makeToggleGroup('[data-sk]', 't1-sk');
makeToggleGroup('[data-sk2]', 't2-sk');
makeToggleGroup('[data-zulage]', 't2-zulage');

// TVöD Bund/VKA toggle
let t1Tabelle = 'bund';
document.getElementById('t1-bund-btn')?.addEventListener('click', () => {
  t1Tabelle = 'bund';
  document.getElementById('t1-bund-btn')!.classList.add('active');
  document.getElementById('t1-vka-btn')!.classList.remove('active');
  (document.getElementById('t1-tabelle') as HTMLInputElement).value = 'bund';
});
document.getElementById('t1-vka-btn')?.addEventListener('click', () => {
  t1Tabelle = 'vka';
  document.getElementById('t1-vka-btn')!.classList.add('active');
  document.getElementById('t1-bund-btn')!.classList.remove('active');
  (document.getElementById('t1-tabelle') as HTMLInputElement).value = 'vka';
});

// Kirchensteuer toggles Tab 1
function makeKircheToggle(neinId: string, jaId: string, bybwId: string | null, stateId: string) {
  document.getElementById(neinId)?.addEventListener('click', () => {
    [neinId,jaId,bybwId].filter(Boolean).forEach(id => document.getElementById(id!)?.classList.remove('active'));
    document.getElementById(neinId)!.classList.add('active');
    (document.getElementById(stateId) as HTMLInputElement).value = 'no';
  });
  document.getElementById(jaId)?.addEventListener('click', () => {
    [neinId,jaId,bybwId].filter(Boolean).forEach(id => document.getElementById(id!)?.classList.remove('active'));
    document.getElementById(jaId)!.classList.add('active');
    (document.getElementById(stateId) as HTMLInputElement).value = 'ja';
  });
  if (bybwId) {
    document.getElementById(bybwId)?.addEventListener('click', () => {
      [neinId,jaId,bybwId].filter(Boolean).forEach(id => document.getElementById(id!)?.classList.remove('active'));
      document.getElementById(bybwId)!.classList.add('active');
      (document.getElementById(stateId) as HTMLInputElement).value = 'bybw';
    });
  }
}
makeKircheToggle('t1-kirche-nein', 't1-kirche-ja', 't1-kirche-bybw', 't1-kirche-state');
makeKircheToggle('t2-kirche-nein', 't2-kirche-ja', null, 't2-kirche-state');

// Kinder toggles
function makeKinderToggle(neinId: string, jaId: string, stateId: string) {
  document.getElementById(neinId)?.addEventListener('click', () => {
    document.getElementById(neinId)!.classList.add('active');
    document.getElementById(jaId)!.classList.remove('active');
    (document.getElementById(stateId) as HTMLInputElement).value = 'no';
  });
  document.getElementById(jaId)?.addEventListener('click', () => {
    document.getElementById(jaId)!.classList.add('active');
    document.getElementById(neinId)!.classList.remove('active');
    (document.getElementById(stateId) as HTMLInputElement).value = 'yes';
  });
}
makeKinderToggle('t1-kinder-nein', 't1-kinder-ja', 't1-kinder-state');
makeKinderToggle('t2-kinder-nein', 't2-kinder-ja', 't2-kinder-state');

// ── Tab 1 Calculate ───────────────────────────────────────────
document.getElementById('t1-berechnen')?.addEventListener('click', () => {
  const eg      = (document.getElementById('t1-eg') as HTMLSelectElement).value;
  const stufe   = parseInt((document.getElementById('t1-stufe') as HTMLSelectElement).value) - 1;
  const tabelle = (document.getElementById('t1-tabelle') as HTMLInputElement).value;
  const sk      = parseInt((document.getElementById('t1-sk') as HTMLInputElement).value);
  const kirche  = (document.getElementById('t1-kirche-state') as HTMLInputElement).value;
  const kinder  = (document.getElementById('t1-kinder-state') as HTMLInputElement).value === 'yes';

  const table  = tabelle === 'bund' ? TVOED_BUND : TVOED_VKA;
  const brutto = table[eg]?.[stufe];
  if (!brutto) return;

  const { kv, pv, rv, av, mLst, soli, kirche: kircheAmt, netto } = calcNetto(brutto, sk, kirche, kinder);

  (document.getElementById('t1-out-brutto') as HTMLElement).textContent = fmt(brutto);
  (document.getElementById('t1-out-kv') as HTMLElement).textContent     = '−' + fmt(kv);
  (document.getElementById('t1-out-pv') as HTMLElement).textContent     = '−' + fmt(pv);
  (document.getElementById('t1-out-rv') as HTMLElement).textContent     = '−' + fmt(rv);
  (document.getElementById('t1-out-av') as HTMLElement).textContent     = '−' + fmt(av);
  (document.getElementById('t1-out-lst') as HTMLElement).textContent    = '−' + fmt(mLst);
  (document.getElementById('t1-out-soli') as HTMLElement).textContent   = soli > 0 ? '−' + fmt(soli) : 'entfällt';
  (document.getElementById('t1-out-netto') as HTMLElement).textContent  = fmt(netto);

  const kircheRow = document.getElementById('t1-kirche-row')!;
  if (kirche !== 'no') {
    kircheRow.style.display = 'flex';
    (document.getElementById('t1-out-kirche') as HTMLElement).textContent = '−' + fmt(kircheAmt);
  } else {
    kircheRow.style.display = 'none';
  }

  // Weihnachtsgeld (TVöD Bund § 20)
  const egNum    = parseInt(eg.replace(/[^\d]/g, '')) || 6;
  const jszFactor = egNum <= 8 ? 0.90 : egNum <= 12 ? 0.80 : 0.60;
  const jsz       = r2(brutto * jszFactor);
  const jszEl     = document.getElementById('t1-out-jsz')!;
  const jszRow    = document.getElementById('t1-jsz-row')!;
  if (tabelle === 'bund') {
    jszEl.textContent    = fmt(jsz);
    jszRow.style.display = 'flex';
  } else {
    jszRow.style.display = 'none';
  }

  document.getElementById('t1-results')!.classList.remove('hidden');
  document.getElementById('t1-results')!.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});

// ── Tab 2 Calculate ───────────────────────────────────────────
document.getElementById('t2-berechnen')?.addEventListener('click', () => {
  const sg     = (document.getElementById('t2-sg') as HTMLSelectElement).value;
  const stufe  = parseInt((document.getElementById('t2-stufe') as HTMLSelectElement).value) - 1;
  const zulage = parseFloat((document.getElementById('t2-zulage') as HTMLInputElement).value);
  const sk     = parseInt((document.getElementById('t2-sk') as HTMLInputElement).value);
  const kirche = (document.getElementById('t2-kirche-state') as HTMLInputElement).value;
  const kinder = (document.getElementById('t2-kinder-state') as HTMLInputElement).value === 'yes';

  const base   = TVOED_SUE[sg]?.[stufe];
  if (!base) return;
  const brutto = r2(base + zulage);

  const { kv, pv, rv, av, mLst, soli, kirche: kircheAmt, netto } = calcNetto(brutto, sk, kirche, kinder);

  (document.getElementById('t2-out-brutto') as HTMLElement).textContent = fmt(brutto);
  (document.getElementById('t2-out-kv') as HTMLElement).textContent     = '−' + fmt(kv);
  (document.getElementById('t2-out-pv') as HTMLElement).textContent     = '−' + fmt(pv);
  (document.getElementById('t2-out-rv') as HTMLElement).textContent     = '−' + fmt(rv);
  (document.getElementById('t2-out-av') as HTMLElement).textContent     = '−' + fmt(av);
  (document.getElementById('t2-out-lst') as HTMLElement).textContent    = '−' + fmt(mLst);
  (document.getElementById('t2-out-soli') as HTMLElement).textContent   = soli > 0 ? '−' + fmt(soli) : 'entfällt';
  (document.getElementById('t2-out-netto') as HTMLElement).textContent  = fmt(netto);

  const kircheRow = document.getElementById('t2-kirche-row')!;
  if (kirche !== 'no') {
    kircheRow.style.display = 'flex';
    (document.getElementById('t2-out-kirche') as HTMLElement).textContent = '−' + fmt(kircheAmt);
  } else {
    kircheRow.style.display = 'none';
  }

  document.getElementById('t2-results')!.classList.remove('hidden');
  document.getElementById('t2-results')!.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
});
</script>