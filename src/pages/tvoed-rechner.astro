---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://nettoklar.de/tvoed-rechner/#webpage",
      "url": "https://nettoklar.de/tvoed-rechner/",
      "name": "TVöD Entgelttabelle 2026 – Gehaltsrechner Öffentlicher Dienst",
      "headline": "TVöD Entgelttabelle 2026 & Gehaltsrechner — Brutto-Netto Öffentlicher Dienst",
      "description": "TVöD Entgelttabelle 2026 ab 1. Mai: Bund, VKA & SuE. Brutto-Netto-Rechner für alle EG-Stufen inkl. Kirchensteuer, Weihnachtsgeld & SuE-Zulagen.",
      "datePublished": "2026-04-27",
      "dateModified": "2026-05-05",
      "inLanguage": "de-DE",
      "isPartOf": { "@id": "https://nettoklar.de/#website" },
      "breadcrumb": { "@id": "https://nettoklar.de/tvoed-rechner/#breadcrumb" },
      "author": {
        "@type": "Person",
        "name": "Riyaansh Mittal",
        "url": "https://nettoklar.de/ueber-uns/"
      },
      "publisher": {
        "@type": "Organization",
        "name": "NettoKlar",
        "url": "https://nettoklar.de"
      },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".fact-strip", "#tvoed-beispiele", "#faq"]
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://nettoklar.de/tvoed-rechner/#breadcrumb",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "NettoKlar", "item": "https://nettoklar.de/" },
        { "@type": "ListItem", "position": 2, "name": "TVöD Rechner 2026", "item": "https://nettoklar.de/tvoed-rechner/" }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://nettoklar.de/tvoed-rechner/#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Wann gilt die neue TVöD Entgelttabelle 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ab 1. Mai 2026 gelten die neuen Tabellen für TVöD Bund und VKA. Die Tarifeinigung sieht eine Entgelterhöhung vor. Bitte prüfen Sie die finalen Werte auf oeffentlicher-dienst.de nach Abschluss der Verhandlungen."
          }
        },
        {
          "@type": "Question",
          "name": "Was verdient EG 9a Stufe 3 netto 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "EG 9a Stufe 3 hat ein Bruttogehalt von ca. €3.748/Monat (TVöD Bund ab Mai 2026). In Steuerklasse 1 ohne Kinder und ohne Kirchensteuer liegt das Netto bei ca. €2.580/Monat. Nutzen Sie den Rechner auf dieser Seite für Ihre genaue Situation."
          }
        },
        {
          "@type": "Question",
          "name": "Wie wird das TVöD Weihnachtsgeld 2026 berechnet?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "TVöD Bund (§20 TVöD): 90% des Novembergehalts (EG 1–8), 80% (EG 9–12), 60% (EG 13–15). Auszahlung im November. Beispiel EG 9a Stufe 3: €3.748 × 80% = €2.998 Weihnachtsgeld (brutto). TVöD VKA-Satz variiert je nach Bundesland."
          }
        },
        {
          "@type": "Question",
          "name": "Was ist der Unterschied zwischen TVöD Bund und VKA?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Beide folgen der Struktur EG 1–15. TVöD Bund gilt für Bundesbehörden (z.B. Bundesministerien, Bundesagentur für Arbeit). TVöD VKA gilt für Städte, Gemeinden und kommunale Einrichtungen — mit leicht abweichenden Grundgehältern. Wählen Sie die korrekte Tabelle über den Toggle im Rechner."
          }
        },
        {
          "@type": "Question",
          "name": "Gilt TVöD auch für Beamte?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nein. Beamte fallen unter das Bundesbesoldungsgesetz (BBesG), nicht den TVöD. TVöD gilt ausschließlich für tariflich Beschäftigte im öffentlichen Dienst."
          }
        },
        {
          "@type": "Question",
          "name": "Wie hoch ist der TVöD Urlaubsanspruch 2026?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Gemäß §26 TVöD haben alle Vollzeitbeschäftigten Anspruch auf 30 Tage bezahlten Jahresurlaub — unabhängig von Entgeltgruppe oder Stufe. Teilzeitbeschäftigte erhalten einen anteiligen Anspruch."
          }
        }
      ]
    },
    {
      "@type": "WebApplication",
      "@id": "https://nettoklar.de/tvoed-rechner/#app",
      "name": "TVöD Brutto-Netto-Rechner 2026",
      "url": "https://nettoklar.de/tvoed-rechner/",
      "description": "Berechnen Sie Ihr monatliches Nettogehalt im öffentlichen Dienst für alle TVöD-Entgeltgruppen (EG 1–15) und SuE-Gruppen (S 2–S 18). Inkl. Kirchensteuer, Weihnachtsgeld und SuE-Zulagen.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web",
      "browserRequirements": "Requires JavaScript",
      "inLanguage": "de-DE",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "EUR"
      }
    }
  ]
};
---

<BaseLayout
  title="TVöD Entgelttabelle 2026 – Gehaltsrechner Öffentlicher Dienst"
  description="TVöD Entgelttabelle 2026 ab 1. Mai: Bund, VKA & SuE. Brutto-Netto-Rechner für alle EG-Stufen inkl. Kirchensteuer, Weihnachtsgeld & SuE-Zulagen."
  schema={schema}
>
  <a href="#main-content" class="sr-only">Zum Inhalt springen</a>

  <main id="main-content">
    <div class="page-wrapper">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
          <li><a href="/">NettoKlar</a></li>
          <li>TVöD Rechner 2026</li>
        </ol>
      </nav>

      <article>

        <!-- Article Header -->
        <header class="article-header">
          <h1>TVöD Entgelttabelle 2026 &amp; Gehaltsrechner — Brutto-Netto Öffentlicher Dienst</h1>
          <div class="author-byline">
            <span>Von <strong>Riyaansh Mittal</strong>, Finanz- und Steuerredakteur</span>
            <span class="byline-sep">·</span>
            <span>Aktualisiert: Mai 2026</span>
            <span class="byline-sep">·</span>
            <span class="freshness-badge">✓ Gültig ab 1. Mai 2026</span>
          </div>
        </header>

        <!-- Direct Answer -->
        <p class="direct-answer">
          Die <strong>TVöD Entgelttabelle 2026</strong> gilt ab <strong>1. Mai 2026</strong> für Bund, VKA und SuE.
          Nutzen Sie den Rechner unten für Ihr persönliches Nettogehalt — oder sehen Sie die
          Beispielgehälter in der Tabelle direkt darunter.
          Weihnachtsgeld (Jahressonderzahlung) wird automatisch mitberechnet.
        </p>

        <!-- Jump Nav -->
        <nav class="article-jump-nav" aria-label="Seitennavigation">
          <span class="jump-nav-label">Auf dieser Seite:</span>
          <a href="#tvoed-beispiele-section">Beispielgehälter</a>
          <a href="#entgelttabelle">Entgelttabelle</a>
          <a href="#gehaltsrechner">Rechner</a>
          <a href="#eg9">EG 9 im Detail</a>
          <a href="#welche-tabelle">Bund vs. VKA vs. SuE</a>
          <a href="#faq">FAQ</a>
        </nav>

        <!-- FAQ Preview Strip -->
        <div class="faq-preview-strip">
          <span class="faq-preview-label">Häufige Fragen:</span>
          <a href="#faq-tabelle-2026">Neue Tabelle ab wann?</a>
          <a href="#faq-eg9a">EG 9a Stufe 3 Netto?</a>
          <a href="#faq-weihnachtsgeld">Weihnachtsgeld 2026?</a>
          <a href="#faq-beamte">Gilt TVöD für Beamte?</a>
          <a href="#faq" class="faq-preview-all">Alle FAQs →</a>
        </div>

        <!-- Fact Strip -->
        <dl class="fact-strip">
          <div class="fact-item">
            <dt>Gilt ab</dt>
            <dd>1. Mai 2026</dd>
          </div>
          <div class="fact-item">
            <dt>Bereiche</dt>
            <dd>Bund · VKA · SuE</dd>
          </div>
          <div class="fact-item">
            <dt>EG-Gruppen</dt>
            <dd>EG 1–15 <span style="font-size:var(--text-xs); font-weight:400; color:var(--color-text-muted)">(Entgeltgruppe)</span></dd>
          </div>
          <div class="fact-item">
            <dt>SuE-Gruppen</dt>
            <dd>S 2–S 18 <span style="font-size:var(--text-xs); font-weight:400; color:var(--color-text-muted)">(Sozial- u. Erzieh.)</span></dd>
          </div>
          <div class="fact-item">
            <dt>Urlaubsanspruch</dt>
            <dd>30 Tage (5-Tage-Woche)</dd>
          </div>
          <div class="fact-item">
            <dt>Weihnachtsgeld</dt>
            <dd>60–90 % (Basis: Ø Jul–Sep)</dd>
          </div>
        </dl>

        <div class="article-body">

          <!-- ══ Statische Beispielgehälter (Crawlable, pre-JS) ══ -->
          <section id="tvoed-beispiele-section" class="anchor-section">
            <h2>TVöD Beispielgehälter 2026 — Typische Einstiegs- und Erfahrungsstufen</h2>
            <p>
              Diese Tabelle zeigt die häufigsten Konstellationen auf einen Blick —
              für Ihre genaue Berechnung mit Kirchensteuer, Kinderfreibetrag und SuE-Zulagen
              nutzen Sie den <a href="#gehaltsrechner">Rechner weiter unten</a>.
              Nettowerte sind Richtwerte für Steuerklasse 1, ohne Kinder, ohne Kirchensteuer.
            </p>

            <!-- Terminologie-Erklärung für Laien -->
            <div class="summary-card" style="margin-bottom: var(--space-6)">
              <p style="font-size: var(--text-sm); font-weight: 600; margin-bottom: var(--space-3)">
                Kurze Erklärung der Abkürzungen — falls Sie neu im Thema sind:
              </p>
              <ul style="font-size: var(--text-sm); color: var(--color-text); line-height: 1.8; list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-2)">
                <li>
                  <strong>EG</strong> = <em>Entgeltgruppe</em> — Ihre Lohnstufe, abhängig von Ausbildung und Tätigkeit.
                  EG 5 ist Einstieg für Fachkräfte; EG 13 für Akademiker. Welche für Sie gilt, steht im Arbeitsvertrag.
                </li>
                <li>
                  <strong>S-Gruppe</strong> (S 2–S 18) = Entgeltgruppe für Sozial- und Erziehungsdienst (Erzieher, Kita, Jugendamt).
                  Gilt nur für TVöD SuE.
                </li>
                <li>
                  <strong>Stufe</strong> = Erfahrungsstufe — wie lange Sie schon im öffentlichen Dienst tätig sind.
                  Stufe 1 ist der erste Tag; Stufe 6 bedeutet viele Jahre Erfahrung.
                  <strong>Sie steigen automatisch auf</strong> — keine Verhandlung nötig.
                </li>
                <li>
                  <strong>TVöD Bund vs. VKA:</strong> Bund = Bundesbehörden (z.B. Bundesministerium).
                  VKA = Kommunale Arbeitgeber (Stadtverwaltung, Krankenhaus). Steht in Ihrem Arbeitsvertrag.
                  Im Zweifel: Bund wählen, wenn Sie für eine Bundesbehörde arbeiten — VKA für alle anderen.
                </li>
              </ul>
            </div>

            <div class="table-scroll">
              <table class="data-table" id="tvoed-beispiele">
                <caption style="text-align:left; font-size:var(--text-sm); color:var(--color-text-muted); margin-bottom:var(--space-3); caption-side:top">
                  Beispielgehälter TVöD Bund ab 1. Mai 2026 · Quelle: §38 TVöD i.V.m. Anlage A (Bund)
                </caption>
                <thead>
                  <tr>
                    <th>EG</th>
                    <th>Stufe</th>
                    <th>Bruttogehalt</th>
                    <th>ca. Netto* (SK 1)</th>
                    <th>Typische Tätigkeiten</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td><strong>EG 3</strong></td>
                    <td>1</td>
                    <td>€2.554</td>
                    <td>~€1.880</td>
                    <td>Bürosachbearbeitung, Poststelle</td>
                  </tr>
                  <tr>
                    <td><strong>EG 5</strong></td>
                    <td>1</td>
                    <td>€2.928</td>
                    <td>~€2.090</td>
                    <td>Fachkraft Verwaltung (Einstieg)</td>
                  </tr>
                  <tr class="highlight-row">
                    <td><strong>EG 9a</strong></td>
                    <td>3</td>
                    <td>€3.748</td>
                    <td>~€2.580</td>
                    <td>Bachelor ÖD, gehobener Dienst</td>
                  </tr>
                  <tr>
                    <td><strong>EG 9b</strong></td>
                    <td>3</td>
                    <td>€3.960</td>
                    <td>~€2.700</td>
                    <td>Techniker, Fachinformatiker</td>
                  </tr>
                  <tr>
                    <td><strong>EG 11</strong></td>
                    <td>3</td>
                    <td>€4.454</td>
                    <td>~€2.980</td>
                    <td>Master ÖD, höherer Dienst (Einstieg)</td>
                  </tr>
                  <tr>
                    <td><strong>EG 13</strong></td>
                    <td>5</td>
                    <td>€6.143</td>
                    <td>~€3.750</td>
                    <td>Wissenschaftler, leitende Referenten</td>
                  </tr>
                  <tr>
                    <td><strong>EG 15</strong></td>
                    <td>6</td>
                    <td>€8.200</td>
                    <td>~€4.700</td>
                    <td>Abteilungsleitung, Top-Führungsebene</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p style="font-size: var(--text-xs); color: var(--color-text-muted)">
              * Nettowerte sind Richtwerte für Steuerklasse 1, keine Kinder, keine Kirchensteuer.
              Individuelle Abweichungen möglich. Bruttowerte ab 1. Mai 2026 —
              bitte vor Publikation gegen finale Tarifwerte prüfen.
              Rechtsgrundlage: §38 TVöD i.V.m. Anlage A (Bund).
            </p>

            <div class="inline-link-callout">
              <span>→</span>
              <span>
                Steuererklärung fristgerecht einreichen:
                <a href="/steuererklarung-frist-2025/">Steuererklärung Frist 2025/2026 — Alle Fristen im Überblick →</a>
              </span>
            </div>
          </section>

          <!-- ══ H2 1: Entgelttabelle (JS-rendered) ══ -->
          <section id="entgelttabelle" class="anchor-section">
            <h2>TVöD Entgelttabelle 2026 — Bund, VKA &amp; SuE</h2>

            <div class="toggle-group" role="group" aria-label="Tabelle auswählen">
              <button class="toggle-btn active" id="tab-bund">TVöD Bund</button>
              <button class="toggle-btn" id="tab-vka">TVöD VKA</button>
              <button class="toggle-btn" id="tab-sue">TVöD SuE</button>
            </div>

            <div class="table-scroll" style="margin-top: var(--space-4)">
              <table class="data-table" id="tvoed-table">
                <thead>
                  <tr>
                    <th>EG</th>
                    <th>Stufe 1</th><th>Stufe 2</th><th>Stufe 3</th>
                    <th>Stufe 4</th><th>Stufe 5</th><th>Stufe 6</th>
                  </tr>
                </thead>
                <tbody id="tvoed-tbody"></tbody>
              </table>
            </div>

            <p style="font-size: var(--text-xs); color: var(--color-text-muted)">
              ⚠️ Tarifwerte ab 1. Mai 2026. Bitte vor Veröffentlichung gegen die finalen Werte auf
              <a href="https://www.oeffentlicher-dienst.de" target="_blank" rel="noopener noreferrer">oeffentlicher-dienst.de</a> prüfen.
            </p>
          </section>

          <!-- ══ H2 2: Rechner ══ -->
          <section id="gehaltsrechner" class="anchor-section">
            <h2>Gehaltsrechner Öffentlicher Dienst 2026</h2>

            <div class="calculator-card">
              <!-- Calc Tab switcher -->
              <div class="toggle-group" role="tablist" style="margin-bottom: var(--space-6)">
                <button class="toggle-btn active" role="tab" aria-selected="true" id="ctab-bund">TVöD Bund / VKA</button>
                <button class="toggle-btn" role="tab" aria-selected="false" id="ctab-sue">TVöD SuE</button>
              </div>

              <!-- ── Tab 1: Bund/VKA ── -->
              <div id="cpanel-bund" role="tabpanel">
                <h2>TVöD Brutto-Netto berechnen</h2>
                <p class="calc-subtitle">Ihr monatliches Nettogehalt im öffentlichen Dienst 2026.</p>

                <div class="calc-grid-2">
                  <div class="calc-field-group">
                    <label class="calc-label" for="t1-eg">Entgeltgruppe</label>
                    <select class="calc-input" id="t1-eg" style="padding-right: var(--space-4)"></select>
                  </div>
                  <div class="calc-field-group">
                    <label class="calc-label" for="t1-stufe">Erfahrungsstufe</label>
                    <select class="calc-input" id="t1-stufe" style="padding-right: var(--space-4)">
                      <option value="1">Stufe 1</option>
                      <option value="2">Stufe 2</option>
                      <option value="3" selected>Stufe 3</option>
                      <option value="4">Stufe 4</option>
                      <option value="5">Stufe 5</option>
                      <option value="6">Stufe 6</option>
                    </select>
                  </div>
                </div>

                <div class="calc-field-group">
                  <label class="calc-label">TVöD Bereich</label>
                  <div class="toggle-group">
                    <button class="toggle-btn active" id="t1-bund-btn">TVöD Bund</button>
                    <button class="toggle-btn" id="t1-vka-btn">TVöD VKA</button>
                  </div>
                  <input type="hidden" id="t1-tabelle" value="bund" />
                </div>

                <div class="calc-field-group">
                  <label class="calc-label" for="t1-sk">Steuerklasse</label>
                  <div class="toggle-group">
                    <button class="toggle-btn active" data-sk="1">SK 1</button>
                    <button class="toggle-btn" data-sk="2">SK 2</button>
                    <button class="toggle-btn" data-sk="3">SK 3</button>
                    <button class="toggle-btn" data-sk="4">SK 4</button>
                    <button class="toggle-btn" data-sk="5">SK 5</button>
                    <button class="toggle-btn" data-sk="6">SK 6</button>
                  </div>
                  <input type="hidden" id="t1-sk" value="1" />
                  <p class="calc-hint">
                    SK 1: ledig · SK 3: verheiratet (höheres Eink.) · SK 5: verheiratet (geringeres Eink.)
                    · <a href="/steuerklasse-finder/">Steuerklasse nicht sicher? →</a>
                  </p>
                </div>

                <div class="calc-grid-2">
                  <div class="calc-field-group">
                    <label class="calc-label">Kirchensteuer</label>
                    <div class="toggle-group">
                      <button class="toggle-btn active" id="t1-kirche-nein">Nein</button>
                      <button class="toggle-btn" id="t1-kirche-ja">Ja (9 %)</button>
                      <button class="toggle-btn" id="t1-kirche-bybw">Ja BY/BW (8 %)</button>
                    </div>
                    <input type="hidden" id="t1-kirche-state" value="no" />
                  </div>
                  <div class="calc-field-group">
                    <label class="calc-label">Kinder</label>
                    <div class="toggle-group">
                      <button class="toggle-btn active" id="t1-kinder-nein">Keine</button>
                      <button class="toggle-btn" id="t1-kinder-ja">Mit Kindern (PV 1,8 %)</button>
                    </div>
                    <input type="hidden" id="t1-kinder-state" value="no" />
                  </div>
                </div>

                <button id="t1-berechnen" class="btn-primary btn-full">Nettogehalt berechnen</button>

                <!-- Results Tab 1 -->
                <div id="t1-results" class="result-block hidden" aria-live="polite">
                  <div class="calc-result-grid">
                    <div class="calc-result-item highlight-result">
                      <span class="result-label">Bruttogehalt</span>
                      <span class="result-badge" id="t1-out-brutto" style="background:var(--color-gross)"></span>
                    </div>
                    <div class="calc-result-item">
                      <span class="result-label">Krankenversicherung (8,75 %)</span>
                      <span class="result-badge" id="t1-out-kv" style="background:var(--color-deduction)"></span>
                    </div>
                    <div class="calc-result-item">
                      <span class="result-label">Pflegeversicherung</span>
                      <span class="result-badge" id="t1-out-pv" style="background:var(--color-deduction)"></span>
                    </div>
                    <div class="calc-result-item">
                      <span class="result-label">Rentenversicherung (9,3 %)</span>
                      <span class="result-badge" id="t1-out-rv" style="background:var(--color-deduction)"></span>
                    </div>
                    <div class="calc-result-item">
                      <span class="result-label">Arbeitslosenversicherung (1,3 %)</span>
                      <span class="result-badge" id="t1-out-av" style="background:var(--color-deduction)"></span>
                    </div>
                    <div class="calc-result-item">
                      <span class="result-label">Lohnsteuer</span>
                      <span class="result-badge" id="t1-out-lst" style="background:var(--color-deduction)"></span>
                    </div>
                    <div class="calc-result-item">
                      <span class="result-label">Solidaritätszuschlag</span>
                      <span class="result-badge" id="t1-out-soli" style="background:var(--color-deduction)"></span>
                    </div>
                    <div class="calc-result-item" id="t1-kirche-row" style="display:none">
                      <span class="result-label">Kirchensteuer</span>
                      <span class="result-badge" id="t1-out-kirche" style="background:var(--color-deduction)"></span>
                    </div>
                    <div class="calc-result-item highlight-result">
                      <span class="result-label">✅ Nettogehalt</span>
                      <span class="result-badge" id="t1-out-netto" style="background:var(--color-net)"></span>
                    </div>
                    <div class="calc-result-item" id="t1-jsz-row">
                      <span class="result-label">Jahressonderzahlung November (TVöD Bund, §20 TVöD)</span>
                      <span class="result-badge" id="t1-out-jsz" style="background:var(--color-primary)"></span>
                    </div>
                  </div>
                  <p style="font-size: var(--text-xs); color: var(--color-text-muted); margin-top: var(--space-4)">
                    Basis: TVöD Entgelttabelle ab 1. Mai 2026. BBG KV/PV €5.812,50/Monat, BBG RV/AV €8.450/Monat.
                    Kein Steuerberatungsersatz.
                  </p>
                </div>
              </div>

              <!-- ── Tab 2: SuE ── -->
              <div id="cpanel-sue" role="tabpanel" class="hidden">
                <h2>TVöD SuE Gehalt berechnen</h2>
                <p class="calc-subtitle">Erzieher, Sozialpädagogen &amp; Kita-Leitungen im kommunalen Dienst.</p>

