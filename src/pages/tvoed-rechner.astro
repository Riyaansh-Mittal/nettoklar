---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "url": "https://nettoklar.de/tvoed-rechner/",
      "name": "TVöD Entgelttabelle 2026 – Gehaltsrechner Öffentlicher Dienst",
      "datePublished": "2026-04-27",
      "dateModified": "2026-04-27",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "NettoKlar", "item": "https://nettoklar.de/" },
          { "@type": "ListItem", "position": 2, "name": "TVöD Rechner 2026", "item": "https://nettoklar.de/tvoed-rechner/" }
        ]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Wann gilt die neue TVöD Entgelttabelle 2026?", "acceptedAnswer": { "@type": "Answer", "text": "Ab 1. Mai 2026 gelten die neuen Tabellen für TVöD Bund und VKA." } },
        { "@type": "Question", "name": "Was verdient EG 9a Stufe 3 netto 2026?", "acceptedAnswer": { "@type": "Answer", "text": "In Steuerklasse 1 liegt das Netto bei ca. €2.850–2.950/Monat. Nutzen Sie den Rechner für Ihre genaue Situation." } },
        { "@type": "Question", "name": "Wie wird das TVöD Weihnachtsgeld 2026 berechnet?", "acceptedAnswer": { "@type": "Answer", "text": "TVöD Bund: 90 % (EG 1–8), 80 % (EG 9–12), 60 % (EG 13–15). Auszahlung November." } },
        { "@type": "Question", "name": "Gilt TVöD auch für Beamte?", "acceptedAnswer": { "@type": "Answer", "text": "Nein. Beamte fallen unter das Bundesbesoldungsgesetz (BBesG), nicht den TVöD." } }
      ]
    },
    {
      "@type": "WebApplication",
      "name": "TVöD Brutto-Netto-Rechner 2026",
      "url": "https://nettoklar.de/tvoed-rechner/",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR" }
    }
  ]
};
---

<BaseLayout
  title="TVöD Entgelttabelle 2026 – Gehaltsrechner Öffentlicher Dienst"
  description="TVöD Entgelttabelle 2026 ab 1. Mai: Bund, VKA & SuE. Brutto-Netto-Rechner für alle EG-Stufen inkl. Kirchensteuer, Weihnachtsgeld & SuE-Zulagen."
  schema={schema}
  slug="tvoed-rechner"
>
  <a href="#main-content" class="sr-only">Zum Inhalt springen</a>

  <main id="main-content">
    <div class="page-wrapper">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
          <li><a href="/">NettoKlar</a></li>
          <li>TVöD Rechner 2026</li>
        </ol>
      </nav>

      <article class="article-body">

        <!-- Article Header -->
        <header class="article-header">
          <h1>TVöD Entgelttabelle 2026 &amp; Gehaltsrechner — Brutto-Netto Öffentlicher Dienst</h1>
          <div class="article-meta">
            <span>Aktualisiert: April 2026</span>
            <span class="freshness-badge">✓ Geprüft 2026</span>
            <span>Gültig ab 1. Mai 2026</span>
          </div>
        </header>

        <!-- Fact Strip -->
        <dl class="fact-strip">
          <div class="fact-item">
            <dt>Gilt ab</dt>
            <dd>1. Mai 2026</dd>
          </div>
          <div class="fact-item">
            <dt>Bereiche</dt>
            <dd>Bund · VKA · SuE</dd>
          </div>
          <div class="fact-item">
            <dt>EG-Gruppen</dt>
            <dd>EG 1–15</dd>
          </div>
          <div class="fact-item">
            <dt>SuE-Gruppen</dt>
            <dd>S 2–S 18</dd>
          </div>
          <div class="fact-item">
            <dt>Urlaubsanspruch</dt>
            <dd>30 Tage (§ 26 TVöD)</dd>
          </div>
          <div class="fact-item">
            <dt>Weihnachtsgeld</dt>
            <dd>60–90 % des Nov-Gehalts</dd>
          </div>
        </dl>

        <!-- H2 1: Entgelttabelle -->
        <section id="entgelttabelle" class="anchor-section">
          <h2>TVöD Entgelttabelle 2026 — Bund, VKA &amp; SuE</h2>

          <div class="toggle-group" role="group" aria-label="Tabelle auswählen">
            <button class="toggle-btn active" id="tab-bund">TVöD Bund</button>
            <button class="toggle-btn" id="tab-vka">TVöD VKA</button>
            <button class="toggle-btn" id="tab-sue">TVöD SuE</button>
          </div>

          <div class="table-scroll" style="margin-top: var(--space-4)">
            <table class="data-table" id="tvoed-table">
              <thead>
                <tr>
                  <th>EG</th>
                  <th>Stufe 1</th><th>Stufe 2</th><th>Stufe 3</th>
                  <th>Stufe 4</th><th>Stufe 5</th><th>Stufe 6</th>
                </tr>
              </thead>
              <tbody id="tvoed-tbody"></tbody>
            </table>
          </div>

          <p style="font-size: var(--text-xs); color: var(--color-text-muted)">
            ⚠️ Tarifwerte ab 1. Mai 2026. Bitte vor Veröffentlichung gegen die finalen Werte auf
            <a href="https://www.oeffentlicher-dienst.de" target="_blank" rel="noopener noreferrer">oeffentlicher-dienst.de</a> prüfen.
          </p>
        </section>

        <!-- H2 2: Rechner -->
        <section id="gehaltsrechner" class="anchor-section">
          <h2>Gehaltsrechner Öffentlicher Dienst 2026</h2>

          <div class="calculator-card">
            <!-- Calc Tab switcher -->
            <div class="toggle-group" role="tablist" style="margin-bottom: var(--space-6)">
              <button class="toggle-btn active" role="tab" aria-selected="true" id="ctab-bund">TVöD Bund / VKA</button>
              <button class="toggle-btn" role="tab" aria-selected="false" id="ctab-sue">TVöD SuE</button>
            </div>

            <!-- ── Tab 1: Bund/VKA ── -->
            <div id="cpanel-bund" role="tabpanel">
              <h2>TVöD Brutto-Netto berechnen</h2>
              <p class="calc-subtitle">Ihr monatliches Nettogehalt im öffentlichen Dienst 2026.</p>

              <div class="calc-grid-2">
                <div class="calc-field-group">
                  <label class="calc-label" for="t1-eg">Entgeltgruppe</label>
                  <select class="calc-input" id="t1-eg" style="padding-right: var(--space-4)"></select>
                </div>
                <div class="calc-field-group">
                  <label class="calc-label" for="t1-stufe">Erfahrungsstufe</label>
                  <select class="calc-input" id="t1-stufe" style="padding-right: var(--space-4)">
                    <option value="1">Stufe 1</option>
                    <option value="2">Stufe 2</option>
                    <option value="3" selected>Stufe 3</option>
                    <option value="4">Stufe 4</option>
                    <option value="5">Stufe 5</option>
                    <option value="6">Stufe 6</option>
                  </select>
                </div>
              </div>

              <div class="calc-field-group">
                <label class="calc-label">TVöD Bereich</label>
                <div class="toggle-group">
                  <button class="toggle-btn active" id="t1-bund-btn">TVöD Bund</button>
                  <button class="toggle-btn" id="t1-vka-btn">TVöD VKA</button>
                </div>
                <input type="hidden" id="t1-tabelle" value="bund" />
              </div>

              <div class="calc-field-group">
                <label class="calc-label" for="t1-sk">Steuerklasse</label>
                <div class="toggle-group">
                  <button class="toggle-btn active" data-sk="1">SK 1</button>
                  <button class="toggle-btn" data-sk="2">SK 2</button>
                  <button class="toggle-btn" data-sk="3">SK 3</button>
                  <button class="toggle-btn" data-sk="4">SK 4</button>
                  <button class="toggle-btn" data-sk="5">SK 5</button>
                  <button class="toggle-btn" data-sk="6">SK 6</button>
                </div>
                <input type="hidden" id="t1-sk" value="1" />
                <p class="calc-hint">SK 1: ledig · SK 3: verheiratet (höheres Eink.) · SK 5: verheiratet (geringeres Eink.)</p>
              </div>

              <div class="calc-grid-2">
                <div class="calc-field-group">
                  <label class="calc-label">Kirchensteuer</label>
                  <div class="toggle-group">
                    <button class="toggle-btn active" id="t1-kirche-nein">Nein</button>
                    <button class="toggle-btn" id="t1-kirche-ja">Ja (9 %)</button>
                    <button class="toggle-btn" id="t1-kirche-bybw">Ja BY/BW (8 %)</button>
                  </div>
                  <input type="hidden" id="t1-kirche-state" value="no" />
                </div>
                <div class="calc-field-group">
                  <label class="calc-label">Kinder</label>
                  <div class="toggle-group">
                    <button class="toggle-btn active" id="t1-kinder-nein">Keine</button>
                    <button class="toggle-btn" id="t1-kinder-ja">Mit Kindern (PV 1,8 %)</button>
                  </div>
                  <input type="hidden" id="t1-kinder-state" value="no" />
                </div>
              </div>

              <button id="t1-berechnen" class="btn-primary btn-full">Nettogehalt berechnen</button>

              <!-- Results Tab 1 -->
              <div id="t1-results" class="result-block hidden" aria-live="polite">
                <div class="calc-result-grid">

                  <div class="calc-result-item highlight-result">
                    <span class="result-label">Bruttogehalt</span>
                    <span class="result-badge" id="t1-out-brutto" style="background:var(--color-gross)"></span>
                  </div>

                  <div class="calc-result-item">
                    <span class="result-label">Krankenversicherung (8,75 %)</span>
                    <span class="result-badge" id="t1-out-kv" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item">
                    <span class="result-label">Pflegeversicherung</span>
                    <span class="result-badge" id="t1-out-pv" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item">
                    <span class="result-label">Rentenversicherung (9,3 %)</span>
                    <span class="result-badge" id="t1-out-rv" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item">
                    <span class="result-label">Arbeitslosenversicherung (1,3 %)</span>
                    <span class="result-badge" id="t1-out-av" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item">
                    <span class="result-label">Lohnsteuer</span>
                    <span class="result-badge" id="t1-out-lst" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item">
                    <span class="result-label">Solidaritätszuschlag</span>
                    <span class="result-badge" id="t1-out-soli" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item" id="t1-kirche-row" style="display:none">
                    <span class="result-label">Kirchensteuer</span>
                    <span class="result-badge" id="t1-out-kirche" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item highlight-result">
                    <span class="result-label">✅ Nettogehalt</span>
                    <span class="result-badge" id="t1-out-netto" style="background:var(--color-net)"></span>
                  </div>

                  <div class="calc-result-item" id="t1-jsz-row">
                    <span class="result-label">Jahressonderzahlung November (TVöD Bund)</span>
                    <span class="result-badge" id="t1-out-jsz" style="background:var(--color-primary)"></span>
                  </div>

                </div>

                <p style="font-size: var(--text-xs); color: var(--color-text-muted); margin-top: var(--space-4)">
                  Basis: TVöD Entgelttabelle ab 1. Mai 2026. BBG KV/PV €5.812,50/Monat, BBG RV/AV €8.450/Monat.
                  Kein Steuerberatungsersatz.
                </p>
              </div>
            </div>

            <!-- ── Tab 2: SuE ── -->
            <div id="cpanel-sue" role="tabpanel" class="hidden">
              <h2>TVöD SuE Gehalt berechnen</h2>
              <p class="calc-subtitle">Erzieher, Sozialpädagogen &amp; Kita-Leitungen im kommunalen Dienst.</p>

              <div class="calc-grid-2">
                <div class="calc-field-group">
                  <label class="calc-label" for="t2-sg">S-Gruppe</label>
                  <select class="calc-input" id="t2-sg" style="padding-right: var(--space-4)"></select>
                </div>
                <div class="calc-field-group">
                  <label class="calc-label" for="t2-stufe">Erfahrungsstufe</label>
                  <select class="calc-input" id="t2-stufe" style="padding-right: var(--space-4)">
                    <option value="1">Stufe 1</option>
                    <option value="2">Stufe 2</option>
                    <option value="3" selected>Stufe 3</option>
                    <option value="4">Stufe 4</option>
                    <option value="5">Stufe 5</option>
                    <option value="6">Stufe 6</option>
                  </select>
                </div>
              </div>

              <div class="calc-field-group">
                <label class="calc-label">Funktionszulage</label>
                <div class="toggle-group">
                  <button class="toggle-btn active" data-zulage="0">Keine</button>
                  <button class="toggle-btn" data-zulage="130.91">Gruppenleitung (+€130,91)</button>
                  <button class="toggle-btn" data-zulage="180.00">Kitaleitung (+€180,00)</button>
                </div>
                <input type="hidden" id="t2-zulage" value="0" />
              </div>

              <div class="calc-field-group">
                <label class="calc-label">Steuerklasse</label>
                <div class="toggle-group">
                  <button class="toggle-btn active" data-sk2="1">SK 1</button>
                  <button class="toggle-btn" data-sk2="2">SK 2</button>
                  <button class="toggle-btn" data-sk2="3">SK 3</button>
                  <button class="toggle-btn" data-sk2="4">SK 4</button>
                  <button class="toggle-btn" data-sk2="5">SK 5</button>
                  <button class="toggle-btn" data-sk2="6">SK 6</button>
                </div>
                <input type="hidden" id="t2-sk" value="1" />
              </div>

              <div class="calc-grid-2">
                <div class="calc-field-group">
                  <label class="calc-label">Kirchensteuer</label>
                  <div class="toggle-group">
                    <button class="toggle-btn active" id="t2-kirche-nein">Nein</button>
                    <button class="toggle-btn" id="t2-kirche-ja">Ja (9 %)</button>
                  </div>
                  <input type="hidden" id="t2-kirche-state" value="no" />
                </div>
                <div class="calc-field-group">
                  <label class="calc-label">Kinder</label>
                  <div class="toggle-group">
                    <button class="toggle-btn active" id="t2-kinder-nein">Keine</button>
                    <button class="toggle-btn" id="t2-kinder-ja">Mit Kindern</button>
                  </div>
                  <input type="hidden" id="t2-kinder-state" value="no" />
                </div>
              </div>

              <button id="t2-berechnen" class="btn-primary btn-full">SuE Gehalt berechnen</button>

              <!-- Results Tab 2 -->
              <div id="t2-results" class="result-block hidden" aria-live="polite">
                <div class="calc-result-grid">

                  <div class="calc-result-item highlight-result">
                    <span class="result-label">Bruttogehalt inkl. Zulage</span>
                    <span class="result-badge" id="t2-out-brutto" style="background:var(--color-gross)"></span>
                  </div>

                  <div class="calc-result-item">
                    <span class="result-label">Krankenversicherung (8,75 %)</span>
                    <span class="result-badge" id="t2-out-kv" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item">
                    <span class="result-label">Pflegeversicherung</span>
                    <span class="result-badge" id="t2-out-pv" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item">
                    <span class="result-label">Rentenversicherung (9,3 %)</span>
                    <span class="result-badge" id="t2-out-rv" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item">
                    <span class="result-label">Arbeitslosenversicherung (1,3 %)</span>
                    <span class="result-badge" id="t2-out-av" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item">
                    <span class="result-label">Lohnsteuer</span>
                    <span class="result-badge" id="t2-out-lst" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item">
                    <span class="result-label">Solidaritätszuschlag</span>
                    <span class="result-badge" id="t2-out-soli" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item" id="t2-kirche-row" style="display:none">
                    <span class="result-label">Kirchensteuer</span>
                    <span class="result-badge" id="t2-out-kirche" style="background:var(--color-deduction)"></span>
                  </div>

                  <div class="calc-result-item highlight-result">
                    <span class="result-label">✅ Nettogehalt</span>
                    <span class="result-badge" id="t2-out-netto" style="background:var(--color-net)"></span>
                  </div>

                </div>
                <p style="font-size: var(--text-xs); color: var(--color-text-muted); margin-top: var(--space-4)">
                  Basis: TVöD SuE Anlage C 2026. Zulage-Beträge bitte beim Arbeitgeber prüfen. Kein Steuerberatungsersatz.
                </p>
              </div>
            </div>

          </div><!-- end calculator-card -->

          <div class="inline-link-callout">
            <span>→</span>
            <span>Steuerklasse nicht sicher? <a href="/steuerklasse-finder/">Steuerklassen-Finder nutzen</a></span>
          </div>
        </section>

        <!-- H2 3: EG 9 Spotlight -->
        <section id="eg9" class="anchor-section">
          <h2>TVöD EG 9 Gehalt 2026 — Alle Stufen (TVöD Bund)</h2>
          <div class="table-scroll">
            <table class="data-table">
              <thead>
                <tr>
                  <th>EG</th>
                  <th>Stufe 1</th><th>Stufe 2</th><th>Stufe 3</th>
                  <th>Stufe 4</th><th>Stufe 5</th><th>Stufe 6</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>EG 9a</strong></td>
                  <td>€3.448</td><td>€3.577</td><td>€3.748</td>
                  <td>€3.918</td><td>€4.066</td><td>€4.213</td>
                </tr>
                <tr class="highlight-row">
                  <td><strong>EG 9b</strong></td>
                  <td>€3.622</td><td>€3.776</td><td><strong>€3.960</strong></td>
                  <td>€4.143</td><td>€4.295</td><td>€4.447</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p style="font-size: var(--text-xs); color: var(--color-text-muted)">
            Bruttowerte TVöD Bund ab 1. Mai 2026. Bitte vor Publikation prüfen.
          </p>
        </section>

        <!-- H2 4: Bund vs VKA vs SuE -->
        <section id="welche-tabelle" class="anchor-section">
          <h2>TVöD Bund vs. VKA vs. SuE — Welche Tabelle gilt für mich?</h2>
          <div class="table-scroll">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Bereich</th>
                  <th>Tabelle</th>
                  <th>Typische Arbeitgeber</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>TVöD Bund</strong></td>
                  <td>EG 1–15</td>
                  <td>Bundesministerien, Bundesagentur, Bundeswehr-zivil</td>
                </tr>
                <tr>
                  <td><strong>TVöD VKA</strong></td>
                  <td>EG 1–15</td>
                  <td>Städte, Gemeinden, Krankenhäuser (kommunal), Sparkassen</td>
                </tr>
                <tr class="highlight-row">
                  <td><strong>TVöD SuE</strong></td>
                  <td>S 2–S 18</td>
                  <td>Kitas, Jugendämter, Sozialeinrichtungen kommunaler Träger</td>
                </tr>
                <tr>
                  <td><strong>TVöD Pflege</strong></td>
                  <td>P 5–P 16</td>
                  <td>Pflegeeinrichtungen kommunaler Träger</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <!-- H2 5: FAQ -->
        <section id="faq" class="anchor-section">
          <h2>Häufige Fragen zum TVöD Rechner 2026</h2>

          <div class="faq-list">

            <details class="faq-item">
              <summary>Wann gilt die neue TVöD Entgelttabelle 2026?</summary>
              <div class="faq-answer">
                <p>Ab 1. Mai 2026 gelten die neuen Tabellen für TVöD Bund und VKA. Bitte prüfen Sie die finalen Tarifwerte auf oeffentlicher-dienst.de nach Abschluss der Verhandlungen.</p>
              </div>
            </details>

            <details class="faq-item">
              <summary>Was verdient EG 9a Stufe 3 netto 2026?</summary>
              <div class="faq-answer">
                <p>EG 9a Stufe 3 hat ein Bruttogehalt von €3.748/Monat. In Steuerklasse 1 ohne Kinder und ohne Kirchensteuer liegt das Netto bei ca. €2.850–2.950/Monat. Nutzen Sie den Rechner oben für Ihre genaue Situation.</p>
              </div>
            </details>

            <details class="faq-item">
              <summary>Wie wird das TVöD Weihnachtsgeld 2026 berechnet?</summary>
              <div class="faq-answer">
                <p>TVöD Bund: 90 % des Novembergehalts (EG 1–8), 80 % (EG 9–12), 60 % (EG 13–15). Auszahlung im November. Beispiel EG 9a Stufe 3: €3.748 × 80 % = <strong>€2.998 Weihnachtsgeld</strong>. TVöD VKA-Satz variiert je nach Bundesland.</p>
              </div>
            </details>

            <details class="faq-item">
              <summary>Was ist der Unterschied zwischen TVöD Bund und VKA?</summary>
              <div class="faq-answer">
                <p>Beide folgen der Struktur EG 1–15. TVöD Bund gilt für Bundesbehörden; TVöD VKA für Städte, Gemeinden und kommunale Einrichtungen — mit leicht abweichenden Grundgehältern. Wählen Sie die korrekte Tabelle über den Toggle im Rechner.</p>
              </div>
            </details>

            <details class="faq-item">
              <summary>Gilt TVöD auch für Beamte?</summary>
              <div class="faq-answer">
                <p>Nein. Beamte fallen unter das Bundesbesoldungsgesetz (BBesG). TVöD gilt ausschließlich für tariflich Beschäftigte im öffentlichen Dienst.</p>
              </div>
            </details>

            <details class="faq-item">
              <summary>Wie hoch ist der TVöD Urlaubsanspruch 2026?</summary>
              <div class="faq-answer">
                <p>Gemäß § 26 TVöD erhalten alle Vollzeitbeschäftigten <strong>30 Tage</strong> bezahlten Jahresurlaub — unabhängig von Entgeltgruppe oder Stufe. Teilzeitbeschäftigte erhalten einen anteiligen Anspruch.</p>
              </div>
            </details>

          </div>
        </section>

