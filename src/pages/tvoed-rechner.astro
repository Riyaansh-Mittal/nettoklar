// ── Toggle group helpers ──────────────────────────────────
function makeToggleGroup(selector: string, hiddenId: string) {
  document.querySelectorAll<HTMLButtonElement>(selector).forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll(selector).forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      (document.getElementById(hiddenId) as HTMLInputElement).value =
        btn.dataset.sk ?? btn.dataset.sk2 ?? btn.dataset.zulage ?? '1';
    });
  });
}
makeToggleGroup('[data-sk]', 't1-sk');
makeToggleGroup('[data-sk2]', 't2-sk');
makeToggleGroup('[data-zulage]', 't2-zulage');

