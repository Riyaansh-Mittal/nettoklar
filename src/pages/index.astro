---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://nettoklar.de/#website",
      "url": "https://nettoklar.de/",
      "name": "NettoKlar",
      "description": "Kostenlose Steuer- und Gehaltsrechner für Deutschland – Steuerklassen, Rentenpunkte, TVöD und mehr.",
      "inLanguage": "de-DE",
      "publisher": { "@id": "https://nettoklar.de/#organization" }
    },
    {
      "@type": "Organization",
      "@id": "https://nettoklar.de/#organization",
      "name": "NettoKlar",
      "url": "https://nettoklar.de/",
      "logo": {
        "@type": "ImageObject",
        "url": "https://nettoklar.de/favicon.svg",
        "width": 300,
        "height": 60
      }
    }
  ]
};
---

<BaseLayout
  title="NettoKlar – Steuer & Rente einfach erklärt"
  description="Steuerklassen-Finder, Rentenpunkte-Rechner, Grundfreibetrag 2026 und TVöD-Rechner – kostenlos und aktuell."
  schema={schema}
>
  <main class="page-wrapper">
    <h1>NettoKlar</h1>
    <p>Dein Brutto-Netto-Rechner 2026 — wird gerade gebaut.</p>
  </main>
</BaseLayout>