          <tr>
            <td data-label="Steuersatz">14% (Eingangssteuersatz)</td>
            <td data-label="Ersparnis">ca. <strong>€35 / Jahr</strong></td>
          </tr>
          <tr>
            <td data-label="Steuersatz">42% (Spitzensteuersatz)</td>
            <td data-label="Ersparnis">ca. <strong>€106 / Jahr</strong></td>
          </tr>
          <tr>
            <td data-label="Steuersatz">Ehepaare (doppelter GFB)</td>
            <td data-label="Ersparnis">ca. <strong>€70 – €212 / Jahr</strong></td>
          </tr>
        </tbody>
      </table>
